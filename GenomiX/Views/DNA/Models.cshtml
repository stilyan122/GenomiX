@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer L
@model IEnumerable<DNAModelListViewModel>

@{
    ViewData["Title"] = L["Title"];
    ViewData["ActiveNav"] = "dna";
}

<div class="container">
    <div style="display:flex;justify-content:space-between;align-items:flex-end;gap:16px;flex-wrap:wrap;">
        <div>
            <div class="gx-sim__kicker">@L["Kicker"]</div>
            <h1 class="home-h2">@L["Header"]</h1>
            <p class="home-sub">@L["Sub"]</p>
        </div>
        <div class="home-cta">
            <a class="btn ghost btn--lg" href="/dna/choose">@L["Btn_New"]</a>
        </div>
    </div>

    <div style="height:14px;"></div>

    @if (!Model.Any())
    {
        <article class="glass-card">
            <h3>@L["Empty_H"]</h3>
            <p>@L["Empty_P"]</p>
            <a class="card-link" href="/dna/choose">@L["Empty_A"]</a>
        </article>
    }
    else
    {
        <div class="tri-grid">
            @foreach (var m in Model)
            {
                <article class="glass-card">
                    <h3>@m.Name</h3>
                    <p>@m.Length bp • Updated @m.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</p>

                    <div class="gx-card-actions">
                        <a class="btn link" href="/dna/builder/@m.Id">@L["Btn_Continue"]</a>
                        <a class="btn ghost btn--sm" href="/dna/models/edit/@m.Id">@L["Btn_Edit"]</a>
                        <form method="post" action="/dna/models/delete/@m.Id">
                            @Html.AntiForgeryToken()
                            <button class="btn danger btn--sm" type="submit"
                                    onclick="return confirm('@L["ConfirmDelete"]');">@L["Btn_Delete"]</button>
                        </form>
                    </div>
                </article>
            }
        </div>
    }
</div>