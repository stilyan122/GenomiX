@{
    ViewData["Title"] = "Custom DNA Builder";
}

<div class="gx-container gx-dna">
    <header class="gx-dna__header">
        <h1 class="title">🧬 Build Your Own DNA</h1>
        <p class="subtitle">
            Create your sequence in real time, switch between <strong>Basic</strong> and <strong>Scientific</strong> view,
            and watch the double helix come alive.
        </p>
    </header>

    <div class="gx-dna__modes" role="group" aria-label="Mode switch">
        <label class="gx-toggle">
            <input type="radio" name="mode" id="basicMode" checked />
            <span>Basic Mode</span>
        </label>
        <label class="gx-toggle">
            <input type="radio" name="mode" id="scientificMode" />
            <span>Scientific Mode</span>
        </label>
    </div>

    <section id="dna-input-section" class="gx-dna__input">
        <label for="sequence" class="gx-label">Enter DNA Strand(s) (A, C, G, T only)</label>
        <textarea id="sequence" name="sequence" class="gx-textarea" rows="4" placeholder="ATGCGTACG..." spellcheck="false"></textarea>
        <p class="gx-help">
            Tip: If you enter one strand, the complementary strand is generated automatically.
            If you prefer, enter two strands on separate lines.
        </p>

        <div class="gx-actions">
            <button id="import-btn" class="btn ghost">📂 Import (.txt / .json)</button>
            <button id="visualize-btn" class="btn primary">🔬 Visualize DNA</button>
        </div>
    </section>

    <section id="dna-visualizer-section" class="gx-dna__viewer" style="display:none;">
        <div id="dna-visual" class="gx-dna__canvas">
        </div>
    </section>
</div>
