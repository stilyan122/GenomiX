@{
    ViewData["Title"] = "Custom DNA Builder";
}

<div class="container py-5">

    <div class="text-center mb-5">
        <h1 class="fw-bold display-5">🧬 Build Your Own DNA</h1>
        <p class="lead text-white">
            Create your sequence in real time, switch between <strong>Basic</strong> and <strong>Scientific</strong> view,
            and watch the double helix come alive.
        </p>
    </div>

    <div class="d-flex justify-content-center mb-4">
        <div class="btn-group" role="group" aria-label="Mode switch">
            <input type="radio" class="btn-check" name="mode" id="basicMode" checked>
            <label class="btn btn-outline-primary" for="basicMode">Basic Mode</label>

            <input type="radio" class="btn-check" name="mode" id="scientificMode">
            <label class="btn btn-outline-success" for="scientificMode">Scientific Mode</label>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-8 mx-auto">
            <label for="sequence" class="form-label fw-semibold">Enter DNA Strand(s) (A, C, G, T bases only)</label>
            <textarea id="sequence" name="sequence" class="form-control text-monospace"
                      rows="4" placeholder="ATGCGTACG..." spellcheck="false"></textarea>
            <div class="form-text text-white">
                Tip: If you enter one strand, the complementary strand will be generated automatically. If 
                you prefer, you can enter the 2 strands on 2 different rows.
            </div>

            <div class="d-flex justify-content-between">
                <button id="import-btn" class="btn btn-outline-secondary">
                    📂 Import Sequence File (.txt or .json)
                </button>
                <button id="visualize-btn" class="btn btn-primary">
                    🔬 Visualize DNA
                </button>
            </div>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-md-10 mx-auto text-center">
            <div id="dna-visual" class="border rounded shadow-sm bg-dark"
                 style="height: 400px; border-radius: 12px; overflow: hidden;">
                <p class="text-white-50 mt-5">
                    [ DNA Visualization will appear here 🧬 ]
                </p>
            </div>
        </div>
    </div>

    <div class="row text-center">
        <div class="col-md-12">
            <button class="btn btn-outline-info me-2">
                <i class="bi bi-plus-circle"></i> Insert Base
            </button>
            <button class="btn btn-outline-warning me-2">
                <i class="bi bi-pencil-square"></i> Mutate Base
            </button>
            <button class="btn btn-outline-danger me-2">
                <i class="bi bi-x-circle"></i> Delete Base
            </button>
            <button class="btn btn-success">
                <i class="bi bi-save"></i> Save DNA
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const dnaSequenceInput = document.getElementById("sequence");
        const importBtn = document.getElementById("import-btn");
        const visualizeBtn = document.getElementById("visualize-btn");
        const visualizer = document.getElementById("dna-visual");

        const complement = { A: "T", T: "A", C: "G", G: "C" };

        function generateComplement(strand) {
            return strand.split("").map(base => complement[base] || "").join("");
        }

        function parseDNAJson(content) {
            let parsed;
            try {
                parsed = JSON.parse(content);
            } catch {
                return { strands: [content.trim().toUpperCase()] }; 
            }

            if (typeof parsed !== "object" || parsed === null) {
                return { strands: [] };
            }

            const keys = Object.keys(parsed);
            const dnaKeys = keys.filter(k =>
                /dna|sequence|seq|strand1?|strand2?|forward|reverse/i.test(k)
            );

            if (dnaKeys.length === 1) {
                const s1 = (parsed[dnaKeys[0]] || "").trim().toUpperCase();
                return { strands: [s1, generateComplement(s1)] };
            }

            if (dnaKeys.length === 2) {
                const s1 = (parsed[dnaKeys[0]] || "").trim().toUpperCase();
                const s2 = (parsed[dnaKeys[1]] || "").trim().toUpperCase();
                return { strands: [s1, s2] };
            }

            if (keys.length === 1) {
                const s1 = (parsed[keys[0]] || "").trim().toUpperCase();
                return { strands: [s1, generateComplement(s1)] };
            }

            return { strands: [] };
        }
-
        importBtn.addEventListener("click", () => {
            const input = document.createElement("input");
            input.type = "file";
            input.accept = ".txt,.json";

            input.onchange = e => {
                const file = e.target.files[0];
                const reader = new FileReader();
                reader.onload = event => {
                    const result = parseDNAJson(event.target.result);
                    if (result.strands.length > 0) {
                        dnaSequenceInput.value = result.strands.join("\n");
                    } else {
                        alert("Could not parse a DNA sequence from file.");
                    }
                };
                reader.readAsText(file);
            };

            input.click();
        });

        // --- Visualize DNA ---
        visualizeBtn.addEventListener("click", () => {
            const sequence = dnaSequenceInput.value.trim().toUpperCase();
            if (!sequence || !/^[ATCG\n]+$/.test(sequence)) {
                alert("Please enter a valid DNA sequence (A/T/C/G only).");
                return;
            }

            dnaSequenceInput.closest(".row").style.display = "none";

            visualizer.innerHTML = `
                <div class="p-3 text-white">
                    <h5>🧬 DNA Strands</h5>
                    <pre>${sequence}</pre>
                </div>`;
        });
    </script>
}