@{
    ViewData["Title"] = "Custom DNA Builder";
    ViewData["ActiveNav"] = "dna";
}

@if (TempData["CustomError"] is string err && !string.IsNullOrWhiteSpace(err))
{
    <div class="gx-msg gx-msg--err">@err</div>
}

<section class="gx-dna-page">
    <div class="container container--wide gx-dna">
        <header class="gx-dna__header">
            <div class="gx-dna__head-left">
                <div class="gx-dna__kicker">DNA Builder</div>
                <h1 class="gx-dna__title">Create a new model</h1>
                <p class="gx-dna__subtitle">
                    Paste <strong>one strand</strong> (we generate the complement) or <strong>two strands</strong> on separate lines.
                    Then we'll create the model and open it in the workspace.
                </p>
            </div>

            <div class="gx-dna__head-right">
                <a class="btn ghost btn--lg" href="/dna/choose">Back</a>
            </div>
        </header>

        <div class="gx-dna__topbar">
            <div class="gx-dna__hintbar">
                <span class="gx-pill">A • C • G • T only</span>
                <span class="gx-pill">Two lines = double strand</span>
                <span class="gx-pill">Import .txt / .json</span>
            </div>
        </div>

        <div id="gxMsg" class="gx-msg" role="status" aria-live="polite" hidden></div>

        <section class="gx-dna__input">
            <div class="gx-card gx-card--pad">
                <label for="modelName" class="gx-label">Model name</label>
                <input id="modelName"
                       class="gx-input"
                       type="text"
                       maxlength="80"
                       placeholder="e.g. Human β-globin demo"
                       autocomplete="off" />

                <label for="sequence" class="gx-label">DNA input</label>

                <form method="post" action="/dna/custom/create" id="customCreateForm" class="gx-hidden">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Name" id="nameHidden" />
                    <input type="hidden" name="RawInput" id="rawInputHidden" />
                    <button type="submit" id="realSubmit" class="gx-hidden"></button>
                </form>

                <textarea id="sequence"
                          class="gx-textarea gx-textarea--xl mono"
                          rows="7"
                          placeholder="ATGCGTACG...
(optional second line = complement)"
                          spellcheck="false"></textarea>

                <div class="gx-dna__help">
                    Tip: If you provide one strand, the complementary strand is generated automatically.
                </div>

                <div class="gx-actions gx-actions--split">
                    <div class="gx-actions__left">
                        <button id="import-btn" class="btn ghost btn--lg" type="button">Import</button>
                        <button id="create-btn" class="btn primary btn--lg" type="button">Create & Open</button>
                    </div>
                </div>
            </div>
        </section>
    </div>
</section>

@section Scripts {
    <script type="module" src="~/js/dna/dna-custom.js" asp-append-version="true"></script>
}
