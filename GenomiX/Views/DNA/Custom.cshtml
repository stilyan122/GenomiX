@{
    ViewData["Title"] = "Custom DNA Builder";
}

<div class="container py-5">

    <div class="text-center mb-5">
        <h1 class="fw-bold display-5">🧬 Build Your Own DNA</h1>
        <p class="lead text-white">
            Create your sequence in real time, switch between <strong>Basic</strong> and <strong>Scientific</strong> view,
            and watch the double helix come alive.
        </p>
    </div>

    <div class="d-flex justify-content-center mb-4">
        <div class="btn-group" role="group" aria-label="Mode switch">
            <input type="radio" class="btn-check" name="mode" id="basicMode" checked>
            <label class="btn btn-outline-primary" for="basicMode">Basic Mode</label>

            <input type="radio" class="btn-check" name="mode" id="scientificMode">
            <label class="btn btn-outline-success" for="scientificMode">Scientific Mode</label>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-8 mx-auto">
            <label for="sequence" class="form-label fw-semibold">Enter DNA Strand(s) (A, C, G, T bases only)</label>
            <textarea id="sequence" name="sequence" class="form-control text-monospace"
                      rows="4" placeholder="ATGCGTACG..." spellcheck="false"></textarea>
            <div class="form-text text-white">
                Tip: If you enter one strand, the complementary strand will be generated automatically. If 
                you prefer, you can enter the 2 strands on 2 different rows.
            </div>

            <div class="d-flex justify-content-between">
                <button id="import-btn" class="btn btn-outline-secondary">
                    📂 Import Sequence File (.txt or .json)
                </button>
                <button id="visualize-btn" class="btn btn-primary">
                    🔬 Visualize DNA
                </button>
            </div>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-md-10 mx-auto text-center">
            <div id="dna-visual" class="border rounded shadow-sm bg-dark"
                 style="height: 400px; border-radius: 12px; overflow: hidden;">
                <p class="text-white-50 mt-5">
                    [ DNA Visualization will appear here 🧬 ]
                </p>
            </div>
        </div>
    </div>

    <div class="row text-center">
        <div class="col-md-12">
            <button class="btn btn-outline-info me-2">
                <i class="bi bi-plus-circle"></i> Insert Base
            </button>
            <button class="btn btn-outline-warning me-2">
                <i class="bi bi-pencil-square"></i> Mutate Base
            </button>
            <button class="btn btn-outline-danger me-2">
                <i class="bi bi-x-circle"></i> Delete Base
            </button>
            <button class="btn btn-success">
                <i class="bi bi-save"></i> Save DNA
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const dnaSequenceInput = document.getElementById("sequence");
        const importBtn = document.getElementById("import-btn");
        const visualizeBtn = document.getElementById("visualize-btn");
        const visualizer = document.getElementById("dna-visual");

        const complement = { A: "T", T: "A", C: "G", G: "C" };

        function generateComplement(strand) {
            return strand.split("").map(base => complement[base] || "").join("");
        }

        // --- Parse DNA or JSON files ---
        function parseDNAJson(content) {
            let parsed;
            let isJson = true;

            try {
                parsed = JSON.parse(content);
            } catch {
                isJson = false;
            }

            if (!isJson) {
                const lines = content
                    .trim()
                    .toUpperCase()
                    .split(/\r?\n/)
                    .filter(l => /^[ATCG]+$/.test(l));

                if (lines.length === 1) {
                    return { strands: [lines[0], generateComplement(lines[0])] };
                }
                if (lines.length >= 2) {
                    return { strands: [lines[0], lines[1]] };
                }

                return { strands: [] };
            }

            if (typeof parsed !== "object" || parsed === null) {
                return { strands: [] };
            }

            const keys = Object.keys(parsed);
            const dnaKeys = keys.filter(k =>
                /^(dna|sequence|seq|strand[12]?|forward|reverse)$/i.test(k.trim())
            );

            if (dnaKeys.length === 1) {
                const s1 = (parsed[dnaKeys[0]] || "").trim().toUpperCase();
                return { strands: [s1, generateComplement(s1)] };
            }

            if (dnaKeys.length === 2) {
                const s1 = (parsed[dnaKeys[0]] || "").trim().toUpperCase();
                const s2 = (parsed[dnaKeys[1]] || "").trim().toUpperCase();
                return { strands: [s1, s2] };
            }

            if (keys.length === 1) {
                const s1 = (parsed[keys[0]] || "").trim().toUpperCase();
                return { strands: [s1, generateComplement(s1)] };
            }

            return { strands: [] };
        }

        // --- Import file handler ---
        importBtn.addEventListener("click", () => {
            const input = document.createElement("input");
            input.type = "file";
            input.accept = ".txt,.json";

            input.onchange = e => {
                const file = e.target.files[0];
                const reader = new FileReader();
                reader.onload = event => {
                    const result = parseDNAJson(event.target.result);
                    if (result.strands.length > 0) {
                        dnaSequenceInput.value = result.strands.join("\n");
                    } else {
                        alert("Could not parse a DNA sequence from file.");
                    }
                };
                reader.readAsText(file);
            };

            input.click();
        });

        // --- Visualization handler ---
        visualizeBtn.addEventListener("click", () => {
            const sequenceText = dnaSequenceInput.value.trim();
            if (!sequenceText) {
                alert("Please enter or import a DNA sequence first!");
                return;
            }
            visualizeDNA(sequenceText);
        });

        // --- Visualization logic ---
        function visualizeDNA(sequenceText) {
            v   isualizer.innerHTML = "";

            const lines = sequenceText.split(/\r?\n/).filter(l => l.trim());
            let strand1, strand2;

            if (lines.length === 1) {
                strand1 = lines[0].trim().toUpperCase();
                strand2 = generateComplement(strand1);
            } else {
                strand1 = lines[0].trim().toUpperCase();
                strand2 = lines[1].trim().toUpperCase();
            }

            if (strand1.length !== strand2.length) {
                alert("Both DNA strands must be of equal length!");
                return;
            }

            const ladder = document.createElement("div");
            ladder.classList.add("dna-ladder");
            visualizer.appendChild(ladder);

            const tooltip = document.createElement("div");
            tooltip.classList.add("tooltip");
            tooltip.textContent = "Ready.";
            visualizer.appendChild(tooltip);

            const progressContainer = document.createElement("div");
            progressContainer.classList.add("progress-container");
            const progressBar = document.createElement("div");
            progressBar.classList.add("progress-bar");
            progressContainer.appendChild(progressBar);
            visualizer.appendChild(progressContainer);

            const prevBtn = document.createElement("button");
            const nextBtn = document.createElement("button");
            prevBtn.classList.add("dna-nav");
            nextBtn.classList.add("dna-nav");
            prevBtn.id = "prev-base";
            nextBtn.id = "next-base";
            prevBtn.textContent = "⟨";
            nextBtn.textContent = "⟩";
            visualizer.appendChild(prevBtn);
            visualizer.appendChild(nextBtn);

            const pairs = [];
            for (let i = 0; i < strand1.length; i++) {
                const base1 = strand1[i];
                const base2 = strand2[i];

                const pair = document.createElement("div");
                pair.classList.add("base-pair");

                const top = document.createElement("div");
                top.classList.add("base", base1);
                top.textContent = base1;

                const bottom = document.createElement("div");
                bottom.classList.add("base", base2);
                bottom.textContent = base2;

                pair.appendChild(top);
                pair.appendChild(bottom);
                ladder.appendChild(pair);
                pairs.push(pair);
            }

            let current = Math.floor(strand1.length / 2); // start centered
            const totalPairs = strand1.length;

            function updateView() {
                const pairWidth = 52; // width + gap
                const centerOffset = (visualizer.clientWidth / 2) - (pairWidth / 2);
                const translateX = -(current * pairWidth) + centerOffset;

                ladder.style.transform = `translateX(${translateX}px)`;

                pairs.forEach(p => p.classList.remove("active"));
                const activePair = pairs[current];
                if (activePair) {
                    activePair.classList.add("active");
                    tooltip.textContent = getPairInfo(strand1[current], strand2[current]);
                }

                progressBar.style.width = `${((current + 1) / totalPairs) * 100}%`;
            }

            function getPairInfo(b1, b2) {
                if ((b1 === "A" && b2 === "T") || (b1 === "T" && b2 === "A"))
                    return `Base ${current + 1}: A–T (2 H bonds)`;
                if ((b1 === "C" && b2 === "G") || (b1 === "G" && b2 === "C"))
                    return `Base ${current + 1}: C–G (3 H bonds)`;
                return `Base ${current + 1}: ${b1}–${b2}`;
            }

            // Button navigation
            nextBtn.addEventListener("click", () => {
                if (current < totalPairs - 1) current++;
                updateView();
            });
            prevBtn.addEventListener("click", () => {
                if (current > 0) current--;
                updateView();
            });

            // Jump to position via progress bar click
            progressContainer.addEventListener("click", e => {
                const rect = progressContainer.getBoundingClientRect();
                const percent = (e.clientX - rect.left) / rect.width;
                current = Math.round(percent * (totalPairs - 1));
                updateView();
            });

            updateView();
        }
    </script>
}