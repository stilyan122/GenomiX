@{
    ViewData["Title"] = "Custom DNA Builder";
}

<div class="container py-5">

    <!-- Header -->
    <div class="text-center mb-5">
        <h1 class="fw-bold display-5">🧬 Build Your Own DNA</h1>
        <p class="lead text-white">
            Create your sequence in real time, switch between <strong>Basic</strong> and <strong>Scientific</strong> view,
            and watch the double helix come alive.
        </p>
    </div>

    <!-- Mode Toggle -->
    <div class="d-flex justify-content-center mb-4">
        <div class="btn-group" role="group" aria-label="Mode switch">
            <input type="radio" class="btn-check" name="mode" id="basicMode" checked>
            <label class="btn btn-outline-primary" for="basicMode">Basic Mode</label>

            <input type="radio" class="btn-check" name="mode" id="scientificMode">
            <label class="btn btn-outline-success" for="scientificMode">Scientific Mode</label>
        </div>
    </div>

    <!-- DNA Input -->
    <div class="row mb-4">
        <div class="col-md-8 mx-auto">
            <label for="sequence" class="form-label fw-semibold">Enter DNA Strand (A, C, G, T only)</label>
            <textarea id="sequence" name="sequence" class="form-control text-monospace"
                      rows="4" placeholder="ATGCGTACG..." spellcheck="false"></textarea>
            <div class="form-text text-muted">
                Tip: If you enter one strand, the complementary strand will be generated automatically.
            </div>
        </div>
    </div>

    <!-- 3D Model Canvas -->
    <div class="row mb-5">
        <div class="col-md-10 mx-auto text-center">
            <div id="dna-visual" class="border rounded shadow-sm bg-dark"
                 style="height: 400px; border-radius: 12px; overflow: hidden;">
                <!-- Placeholder: Three.js / Babylon.js will render here -->
                <p class="text-white-50 mt-5">
                    [ DNA Visualization will appear here 🧬 ]
                </p>
            </div>
        </div>
    </div>

    <!-- Controls -->
    <div class="row text-center">
        <div class="col-md-12">
            <button class="btn btn-outline-info me-2">
                <i class="bi bi-plus-circle"></i> Insert Base
            </button>
            <button class="btn btn-outline-warning me-2">
                <i class="bi bi-pencil-square"></i> Mutate Base
            </button>
            <button class="btn btn-outline-danger me-2">
                <i class="bi bi-x-circle"></i> Delete Base
            </button>
            <button class="btn btn-success">
                <i class="bi bi-save"></i> Save DNA
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // === Scene setup ===
        const container = document.getElementById("dna-visual");
        const scene = new THREE.Scene();
        scene.background = new THREE.Color(0x111111);

        const camera = new THREE.PerspectiveCamera(45, container.clientWidth / container.clientHeight, 0.1, 1000);
        camera.position.z = 50;

        const renderer = new THREE.WebGLRenderer({ antialias: true });
        renderer.setSize(container.clientWidth, container.clientHeight);
        container.appendChild(renderer.domElement);

        // === Lighting ===
        const light = new THREE.PointLight(0xffffff, 1.2);
        light.position.set(20, 20, 20);
        scene.add(light);

        const ambient = new THREE.AmbientLight(0x404040);
        scene.add(ambient);

        // === DNA parameters ===
        const helixRadius = 5;
        const helixHeight = 30;
        const turns = 15;
        const stepsPerTurn = 20;

        const materialA = new THREE.MeshPhongMaterial({ color: 0xff6666 });
        const materialT = new THREE.MeshPhongMaterial({ color: 0x66ccff });
        const materialC = new THREE.MeshPhongMaterial({ color: 0x99ff99 });
        const materialG = new THREE.MeshPhongMaterial({ color: 0xffff66 });

        const sphereGeometry = new THREE.SphereGeometry(0.4, 16, 16);

        function createStrand(offset) {
            const strand = new THREE.Group();
            for (let i = 0; i < turns * stepsPerTurn; i++) {
                const angle = (i / stepsPerTurn) * Math.PI * 2;
                const y = (i / (turns * stepsPerTurn)) * helixHeight - helixHeight / 2;
                const x = helixRadius * Math.cos(angle + offset);
                const z = helixRadius * Math.sin(angle + offset);

                // Alternate bases for visual effect
                const base = new THREE.Mesh(sphereGeometry,
                    [materialA, materialT, materialC, materialG][i % 4]);
                base.position.set(x, y, z);
                strand.add(base);
            }
            return strand;
        }

        const strand1 = createStrand(0);
        const strand2 = createStrand(Math.PI);
        scene.add(strand1);
        scene.add(strand2);

        // === Backbone connector lines ===
        const backboneMaterial = new THREE.LineBasicMaterial({ color: 0xffffff });
        const backboneGeometry = new THREE.BufferGeometry();
        const positions = [];

        for (let i = 0; i < turns * stepsPerTurn; i++) {
            const angle = (i / stepsPerTurn) * Math.PI * 2;
            const y = (i / (turns * stepsPerTurn)) * helixHeight - helixHeight / 2;

            const x1 = helixRadius * Math.cos(angle);
            const z1 = helixRadius * Math.sin(angle);

            const x2 = helixRadius * Math.cos(angle + Math.PI);
            const z2 = helixRadius * Math.sin(angle + Math.PI);

            positions.push(x1, y, z1, x2, y, z2);
        }

        backboneGeometry.setAttribute('position', new THREE.Float32BufferAttribute(positions, 3));
        const backbone = new THREE.LineSegments(backboneGeometry, backboneMaterial);
        scene.add(backbone);

        // === Animation loop ===
        function animate() {
            requestAnimationFrame(animate);
            strand1.rotation.y += 0.005;
            strand2.rotation.y += 0.005;
            backbone.rotation.y += 0.005;
            renderer.render(scene, camera);
        }
        animate();

        // === Resize handler ===
        window.addEventListener("resize", () => {
            camera.aspect = container.clientWidth / container.clientHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(container.clientWidth, container.clientHeight);
        });
    </script>
}
