@model DNABuilderViewModel

@{
    ViewData["Title"] = "DNA Builder";
    ViewData["ActiveNav"] = "dna";
}

<section class="gx-dna-page">
    <div class="container container--wide gx-dna">
        <header class="gx-dna__header">
            <div class="gx-dna__head-left">
                <div class="gx-dna__kicker">DNA Builder</div>
                <h1 class="gx-dna__title">Model workspace</h1>
                <p class="gx-dna__subtitle">
                    <span class="mono">Model</span> <span class="mono">@Model.Name</span>
                    • <strong>@Model.Length</strong> bp
                </p>
            </div>

            <div class="gx-dna__head-right">
                <a class="btn ghost btn--lg" href="/dna/models">Back to models</a>
            </div>
        </header>

        <div class="gx-dna__topbar">
            <div class="gx-dna__modes" role="group" aria-label="Mode switch">
                <label class="gx-toggle">
                    <input type="radio" name="mode" id="basicMode" checked />
                    <span>Basic Mode</span>
                </label>
                <label class="gx-toggle">
                    <input type="radio" name="mode" id="scientificMode" />
                    <span>Scientific Mode</span>
                </label>
            </div>

            <div class="gx-dna__hintbar">
                <span class="gx-pill">2D ladder</span>
                <span class="gx-pill">3D helix</span>
                <span class="gx-pill">Inspector</span>
            </div>
        </div>

        <section id="dna-input-section" class="gx-hidden">
            <textarea id="sequence" class="gx-hidden" spellcheck="false"></textarea>
            <button id="import-btn" type="button" class="gx-hidden"></button>
            <button id="visualize-btn" type="button" class="gx-hidden"></button>
        </section>


        <section id="dna-visualizer-section" class="gx-dna__viewer">
            <div class="gx-dna__viewerbar">
                <a id="exit-btn" class="gx-btn gx-btn--ghost gx-btn-exit" href="/dna/models">Exit</a>

                <button id="save-btn" type="button" class="gx-btn gx-btn--accent">
                    Save model
                </button>

                <button id="history-btn" class="gx-btn gx-btn--ghost" type="button">
                    History
                </button>

                <div class="gx-dna__viewerhint">
                    Use ⟨ ⟩ to move base, click the progress bar to jump.
                </div>

                <div class="gx-dna__vieweractions">
                    <button id="scan-dna-btn" type="button" class="gx-btn gx-btn--accent">
                        Scan DNA
                    </button>

                    <button id="repair-dna-btn" type="button" class="gx-btn gx-btn--danger is-hidden">
                        Repair DNA
                    </button>

                    <button id="undo-btn" class="gx-btn gx-btn--soft" type="button" aria-label="Undo" title="Undo">
                        <span class="gx-action__icon">↶</span>
                        <span class="gx-action__text">Undo</span>
                    </button>

                    <button id="redo-btn" class="gx-btn gx-btn--soft" type="button" aria-label="Redo" title="Redo">
                        <span class="gx-action__icon">↷</span>
                        <span class="gx-action__text">Redo</span>
                    </button>

                    <div id="gx-helix-actions"></div>
                </div>
            </div>

          <div id="dnaMount"
               data-s1="@Model.Strand1"
               data-s2="@Model.Strand2">
          </div>

          <input type="hidden" id="gx-model-id" value="@Model.ModelId" />

            <div id="dna-visual" class="gx-dna__canvas gx-helix-wrap">
                <div id="gx-legend-3d" class="gx-dna-legend gx-hidden">
                    <div class="row"><span class="dot c"></span><span>C</span></div>
                    <div class="row"><span class="dot n"></span><span>N</span></div>
                    <div class="row"><span class="dot o"></span><span>O</span></div>
                    <div class="row"><span class="dot p"></span><span>P</span></div>
                    <div class="row"><span class="dot h"></span><span>H</span></div>
                    <div class="row"><span class="hbond"></span><span>H-bond</span></div>
                </div>
            </div>

          <div id="dna-visual" class="gx-dna__canvas"></div>
        </section>
    </div>
</section>

@section Scripts {
    <script type="module" src="~/js/dna/dna-page.js" asp-append-version="true"></script>

    <script type="module">
        document.addEventListener("DOMContentLoaded", () => {
            const mount = document.getElementById("dnaMount");
            const s1 = mount?.dataset?.s1 ?? "";
            const s2 = mount?.dataset?.s2 ?? "";
            
            const textarea = document.getElementById("sequence");
            if (textarea) textarea.value = `${s1}\n${s2}`;
            
            const btn = document.getElementById("visualize-btn");
            btn?.click();
            
            const mode = document.getElementById("basicMode");
            mode?.dispatchEvent(new Event("change", { bubbles: true }));
        });
    </script>
}