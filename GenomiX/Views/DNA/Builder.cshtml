@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer L

@model DNABuilderViewModel

@{
    ViewData["Title"] = L["Title"];
    ViewData["ActiveNav"] = "dna";
}

<form id="gx-anti-forgery-form" method="post" class="gx-hidden">
    @Html.AntiForgeryToken()
</form>

<section class="gx-dna-page">
    <div class="container container--wide gx-dna">
        <header class="gx-dna__header">
            <div class="gx-dna__head-left">
                <div class="gx-dna__kicker">@L["Kicker"]</div>
                <h1 class="gx-dna__title">@L["WorkspaceTitle"]</h1>
                <p class="gx-dna__subtitle">
                    <span class="mono">@L["Label_Model"]</span> <span class="mono">@Model.Name</span>
                    • <strong>@Model.Length</strong> bp
                </p>
            </div>

            <div class="gx-dna__head-right">
                <a class="btn ghost btn--lg" href="/dna/models">@L["BackToModels"]</a>
            </div>
        </header>

        <div class="gx-dna__topbar">
            <div class="gx-dna__modes" role="group" aria-label="Mode switch">
                <label class="gx-toggle">
                    <input type="radio" name="mode" id="basicMode" checked />
                    <span>@L["BasicMode"]</span>
                </label>
                <label class="gx-toggle">
                    <input type="radio" name="mode" id="scientificMode" />
                    <span>@L["ScientificMode"]</span>
                </label>
            </div>

            <div class="gx-dna__hintbar">
                <span class="gx-pill">@L["Pill_2D"]</span>
                <span class="gx-pill">@L["Pill_3D"]</span>
                <span class="gx-pill">@L["Pill_Inspector"]</span>
            </div>
        </div>

        <section id="dna-input-section" class="gx-hidden">
            <textarea id="sequence" class="gx-hidden" spellcheck="false"></textarea>
            <button id="import-btn" type="button" class="gx-hidden"></button>
            <button id="visualize-btn" type="button" class="gx-hidden"></button>
        </section>


        <section id="dna-visualizer-section" class="gx-dna__viewer">
            <div class="gx-dna__viewerbar">
                <a id="exit-btn" class="gx-btn gx-btn--ghost gx-btn-exit" href="/dna/models">@L["Exit"]</a>

                <button id="save-btn" type="button" class="gx-btn gx-btn--accent">@L["SaveModel"]</button>

                <button id="history-btn" class="gx-btn gx-btn--ghost" type="button">@L["History"]</button>

                <button id="scan-dna-btn" type="button" class="gx-btn gx-btn--accent">@L["ScanDNA"]</button>

                <button id="scan-disease-btn"
                        type="button"
                        class="gx-btn gx-btn--accent"
                        aria-label="@L["ScanDiseases"]"
                        title="@L["ScanDiseases"]">
                    @L["ScanDiseases"]
                </button>

                <button id="compare-btn" class="gx-btn gx-btn--ghost">
                    @L["CompareDNA"]
                </button>

                <button id="repair-dna-btn" type="button" 
                class="gx-btn gx-btn--danger is-hidden">@L["RepairDNA"]</button>

                <button id="undo-btn"
                        class="gx-btn gx-btn--soft"
                        type="button"
                        aria-label="@L["Undo"]"
                        title="@L["Undo"]">
                    <span class="gx-action__icon">↶</span>
                    <span class="gx-action__text">@L["Undo"]</span>
                </button>

                <button id="redo-btn"
                        class="gx-btn gx-btn--soft"
                        type="button"
                        aria-label="@L["Redo"]"
                        title="@L["Redo"]">
                    <span class="gx-action__icon">↷</span>
                    <span class="gx-action__text">@L["Redo"]</span>
                </button>

                <div id="gx-helix-actions"></div>

                <div class="gx-dna__viewerhint">@L["ViewerHint"]</div>

            </div>

          <div id="dnaMount"
               data-s1="@Model.Strand1"
               data-s2="@Model.Strand2">
          </div>

          <input type="hidden" id="gx-model-id" value="@Model.ModelId" />

          <div id="dna-visual" class="gx-dna__canvas">
                <div id="gx-legend-3d" class="gx-dna-legend gx-hidden">
                    <div class="row"><span class="dot c"></span><span>@L["Legend_C"]</span></div>
                    <div class="row"><span class="dot n"></span><span>@L["Legend_N"]</span></div>
                    <div class="row"><span class="dot o"></span><span>@L["Legend_O"]</span></div>
                    <div class="row"><span class="dot p"></span><span>@L["Legend_P"]</span></div>
                    <div class="row"><span class="dot h"></span><span>@L["Legend_H"]</span></div>
                    <div class="row"><span class="hbond"></span><span>@L["Legend_HBond"]</span></div>
                </div>
          </div>
        </section>
    </div>
</section>

@section Scripts {
    <script type="module" src="~/js/dna/dna-page.js" asp-append-version="true"></script>

    <script type="module">
        document.addEventListener("DOMContentLoaded", () => {
            const mount = document.getElementById("dnaMount");
            const s1 = mount?.dataset?.s1 ?? "";
            const s2 = mount?.dataset?.s2 ?? "";
            
            const textarea = document.getElementById("sequence");
            if (textarea) textarea.value = `${s1}\n${s2}`;
            
            const btn = document.getElementById("visualize-btn");
            btn?.click();
            
            const mode = document.getElementById("basicMode");
            mode?.dispatchEvent(new Event("change", { bubbles: true }));
        });
    </script>
}