@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer L

@{
    ViewData["Title"] = L["Title"];
    ViewData["ActiveNav"] = "dna";
}

<section class="gx-choose">
    <div class="container">
        <header class="gx-choose__head">
            <div>
                <h1 class="gx-choose__title">@L["TitleText"]</h1>
                <p class="gx-choose__sub">@L["Subtitle"]</p>
            </div>

            <div class="gx-choose__actions">
                <a class="btn ghost btn--lg" href="/dna/models">@L["MyModels"]</a>
            </div>
        </header>

        <div class="gx-choose__grid">
            <article class="glass-card gx-choose__card">
                <div class="gx-choose__icon" aria-hidden="true">🧬</div>
                <h3 class="gx-choose__h">@L["PredefTitle"]</h3>
                <p class="gx-choose__p">@L["PredefDesc"]</p>
                <a class="btn primary btn--lg gx-choose__btn" href="/dna/predefined">@L["BrowseTemplates"]</a>
            </article>

            <article class="glass-card gx-choose__card">
                <div class="gx-choose__icon" aria-hidden="true">✍️</div>
                <h3 class="gx-choose__h">@L["CustomTitle"]</h3>
                <p class="gx-choose__p">@L["CustomDesc"]</p>
                <a class="btn ghost btn--lg gx-choose__btn" href="/dna/custom">@L["CreateCustom"]</a>
            </article>
        </div>
    </div>
</section>