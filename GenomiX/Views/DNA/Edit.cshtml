@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer L

@model EditDNAModelInputModel
@{
    ViewData["Title"] = L["Title"];
    ViewData["ActiveNav"] = "dna";
}

<div class="container gx-edit">
    <div class="gx-edit__head">
        <div>
            <div class="gx-edit__kicker">@L["Kicker"]</div>
            <h1 class="gx-edit__title">@L["Header"]</h1>
            <p class="gx-edit__sub">@L["Sub"]</p>
        </div>

        <a class="btn ghost btn--sm" href="/dna/models">@L["Back"]</a>
    </div>

    <div class="gx-edit__grid">
        <section class="gx-card gx-card--form">
            <form method="post" action="/dna/models/edit" class="gx-form">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="gx-field">
                    <label class="gx-label" asp-for="Name">@L["Lbl_ModelName"]</label>

                    <div class="gx-inputwrap">
                        <input asp-for="Name"
                               class="gx-input"
                               maxlength="60"
                               autocomplete="off"
                               placeholder="@L["Ph_Name"]" />
                        <div class="gx-inputglow"></div>
                    </div>

                    <div class="gx-hint">@L["Hint_Max60"]</div>
                    <span asp-validation-for="Name" class="gx-error"></span>
                </div>

                <div class="gx-divider"></div>

                <div class="gx-actions">
                    <button class="btn btn--lg" type="submit">@L["Btn_Save"]</button>
                    <a class="btn ghost btn--lg" href="/dna/models">@L["Btn_Cancel"]</a>
                </div>
            </form>
        </section>

        <aside class="gx-card gx-card--tips">
            <div class="gx-tips">
                <div class="gx-tips__title">@L["TipsTitle"]</div>

                <div class="gx-tip">
                    <div class="gx-dot"></div>
                    <div>
                        <div class="gx-tip__h">@L["Tip1_H"]</div>
                        <div class="gx-tip__p">@L["Tip1_P"]</div>
                    </div>
                </div>

                <div class="gx-tip">
                    <div class="gx-dot"></div>
                    <div>
                        <div class="gx-tip__h">@L["Tip2_H"]</div>
                        <div class="gx-tip__p">@L["Tip2_P"]</div>
                    </div>
                </div>

                <div class="gx-tip">
                    <div class="gx-dot"></div>
                    <div>
                        <div class="gx-tip__h">@L["Tip3_H"]</div>
                        <div class="gx-tip__p">@L["Tip3_P"]</div>
                    </div>
                </div>
            </div>
        </aside>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}