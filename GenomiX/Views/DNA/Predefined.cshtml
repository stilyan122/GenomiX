@model IEnumerable<SequenceViewModel>

@{
    ViewData["Title"] = "Predefined DNA";
}

<div class="container mt-5">
    <h2>Choose a Predefined DNA Sequence</h2>
    <ul class="list-group mt-4">
        @foreach (var seq in Model)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                    <strong>@seq.Species</strong> – @seq.Sequence.Length bp
                </div>
                <a class="btn btn-sm btn-primary" href="/dna/load/@seq.Id">Select</a>
            </li>
        }
    </ul>
</div>
