@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer L

@model IEnumerable<SequenceViewModel>

@{
    ViewData["Title"] = L["Title"];
    ViewData["ActiveNav"] = "dna";

    var items = Model?.ToList() ?? new List<SequenceViewModel>();
    var species = items
        .Select(x => (x.Species ?? "").Trim())
        .Where(x => x.Length > 0)
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(x => x)
        .ToList();
}

<section class="gx-predef">
    <div class="container">
        <header class="gx-predef__head">
            <div>
                <h1 class="gx-predef__title">@L["Header"]</h1>
                <p class="gx-predef__sub">@L["Sub"]</p>
            </div>

            <div class="gx-predef__actions">
                <a class="btn ghost btn--lg" href="/dna/choose">@L["Back"]</a>
            </div>
        </header>

        <div class="gx-predef__toolbar">
            <div class="gx-predef__search">
                <input id="gxPredefSearch" class="gx-predef__input" type="search" placeholder="@L["Ph_Search"]" autocomplete="off" />
                <span class="gx-predef__hint">@L["Hint_Filter"]</span>
            </div>

            <div class="gx-predef__chips" role="list" aria-label="Species filters">
                <button class="gx-predef__chip is-active" type="button" data-filter="all">@L["All"]</button>
                @foreach (var sp in species)
                {
                    <button class="gx-predef__chip" type="button" data-filter="@sp">@sp</button>
                }
            </div>
        </div>

        @if (!items.Any())
        {
            <article class="glass-card">
                <h3>@L["Empty_H"]</h3>
                <p>@L["Empty_P1"]<span class="mono">@L["Empty_Ref"]</span> @L["Empty_P2"]</p>
            </article>
        }
        else
        {
            <div class="gx-predef__grid" id="gxPredefGrid">
                @foreach (var seq in items)
                {
                    var sp = (seq.Species ?? "").Trim();
                    var len = (seq.Sequence ?? "").Length;

                    <article class="glass-card gx-predef__card" data-species="@sp">
                        <div class="gx-predef__top">
                            <div class="gx-predef__titleRow">
                                <div class="gx-predef__species">@sp</div>
                                <div class="gx-predef__meta">@L["Meta_CreatedBy"]@seq.CreatedBy</div>
                                <div class="gx-predef__meta">@len bp</div>
                            </div>
                            <div class="gx-predef__badge" title="@L["Title_Template"]">@L["Badge_Template"]</div>
                        </div>

                        <div class="gx-predef__preview mono" aria-hidden="true">
                            @{
                                var preview = (seq.Sequence ?? "");
                                if (preview.Length > 96) preview = preview.Substring(0, 96) + "…";
                            }
                            @preview
                        </div>

                        <div class="gx-predef__bottom">
                            <form method="post" action="/dna/predefined/create/@seq.Id" class="gx-predef__form">
                                @Html.AntiForgeryToken()

                                <input class="gx-predef__name"
                                       name="Name"
                                       maxlength="80"
                                       required
                                       placeholder="@L["Ph_ModelNameReq"]"
                                       autocomplete="off" />

                                <button type="submit" class="btn primary btn--lg gx-predef__btn">@L["Btn_UseTemplate"]</button>
                            </form>

                            <div class="gx-predef__note">
                                @L["CreatesIn"]<a class="gx-predef__link" href="/dna/models">@L["MyModels"]</a>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
    </div>
</section>

@section Scripts {
    <script type="module" src="~/js/dna/dna-predefined.js" asp-append-version="true"></script>
}