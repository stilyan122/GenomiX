@model IEnumerable<PopulationViewModel>
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer L

@{
    ViewData["Title"] = "Public Simulations";
    ViewData["ActiveNav"] = "public";
}

<section class="gx-sim-page">
    <div class="container container--wide gx-sim">

        <header class="gx-sim__header gx-sim__header--index">
            <div class="gx-sim__head-left">
                <div class="gx-sim__kicker">🌐 Community</div>
                <h1 class="gx-sim__title">Public Simulations</h1>
                <p class="gx-sim__subtitle">
                    Simulations published by Scientists — watch them live in read-only mode.
                </p>
            </div>
            <div class="gx-sim__head-right gx-sim__head-right--index">
                <a class="gx-btn gx-btn--ghost" href="/simulations">Back</a>
            </div>
        </header>

        @if (Model == null || !Model.Any())
        {
            <div class="gx-empty gx-empty--sim">
                <div class="gx-empty__badge">No public simulations yet</div>
                <div class="gx-empty__title">Nothing here yet</div>
                <div class="gx-empty__text">
                    Scientists can publish their simulations so everyone can watch them.
                    Check back later or ask a Scientist to share one.
                </div>
            </div>
        }
        else
        {
            <div class="gx-sim__toolbar">
                <div class="gx-sim__count">
                    <span class="gx-dot"></span>
                    <strong>@Model.Count()</strong> public simulations
                </div>
            </div>

            <div class="gx-simgrid">
                @foreach (var p in Model)
                {
                    var orgCount = p.Organisms?.Count ?? 0;
                    var aliveCount = p.Organisms?.Count(o => o.Status != "dead") ?? 0;

                    <article class="gx-simtile gx-simtile--public">
                        <div class="gx-simtile__glow"></div>

                        @* Published badge *@
                        <div class="gx-simtile__pub-badge">🌐 Public</div>

                        <header class="gx-simtile__top">
                            <div>
                                <div class="gx-simtile__title">@p.Name</div>
                                <div class="gx-simtile__owner">by @p.OwnerName</div>
                            </div>
                            <div class="gx-simtile__meta">
                                <div><span class="gx-meta__k">Published</span><span class="gx-meta__v mono">@p.PublishedAt</span></div>
                            </div>
                        </header>

                        <div class="gx-simtile__stats">
                            <div class="gx-stat">
                                <div class="gx-stat__k">Organisms</div>
                                <div class="gx-stat__v mono">@orgCount</div>
                                <div class="gx-stat__bar">
                                    <div class="gx-stat__fill" style="width:@(Math.Min(100, 12 + orgCount / 50.0 * 88).ToString("0"))%"></div>
                                </div>
                            </div>
                            <div class="gx-stat">
                                <div class="gx-stat__k">Base model</div>
                                <div class="gx-stat__v mono">@p.BaseModelName</div>
                                <div class="gx-stat__hint">DNA reference</div>
                            </div>
                        </div>

                        <div class="gx-simtile__actions gx-simtile__actions--grid">
                            <a class="gx-btn gx-btn--primary gx-btn--full gx-btn--watch" href="/simulations/run/@p.Id">
                                👁 Watch Live
                            </a>
                        </div>

                    </article>
                }
            </div>
        }
    </div>
</section>
