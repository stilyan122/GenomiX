@model CreatePopulationViewModel
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer L

@{
    ViewData["Title"] = L["SimCreate_PageTitle"].Value;
    ViewData["ActiveNav"] = "simulations";
}

<section class="gx-sim-page">
    <div class="container container--wide gx-sim">
        <header class="gx-sim__header gx-sim__header--index">
            <div class="gx-sim__head-left">
                <div class="gx-sim__kicker">@L["SimCreate_Kicker_Simulations"]</div>
                <h1 class="gx-sim__title">@L["SimCreate_Title"]</h1>
                <p class="gx-sim__subtitle">@L["SimCreate_Subtitle"]</p>
            </div>

            <div class="gx-sim__head-right gx-sim__head-right--index">
                <a class="gx-btn gx-btn--ghost" href="/simulations">@L["Common_Back"]</a>
            </div>
        </header>

        <div class="gx-simcreate">
            <form method="post" class="gx-form gx-card gx-simform">
                @Html.AntiForgeryToken()

                <div class="gx-simform__glow"></div>

                <div class="gx-simform__grid">
                    <div class="gx-field">
                        <label class="gx-label" asp-for="Name">@L["SimCreate_SimulationName_Label"]</label>
                        <input class="gx-input" asp-for="Name" placeholder="@L["SimCreate_SimulationName_Placeholder"]" />
                        <span class="gx-val" asp-validation-for="Name"></span>
                    </div>

                    <div class="gx-field">
                        <label class="gx-label" asp-for="Size">@L["SimCreate_PopulationSize_Label"]</label>
                        <input class="gx-input" asp-for="Size" type="number" min="2" max="5000" step="1" />
                        <div class="gx-help">@L["SimCreate_PopulationSize_Help"]</div>
                        <span class="gx-val" asp-validation-for="Size"></span>
                    </div>

                    <div class="gx-field">
                        <label class="gx-label" for="Species">@L["SimCreate_OrganismType_Label"]</label>
                        <select class="gx-select" id="Species" name="Species">
                            <option value="mouse">@L["SimCreate_Species_Mouse"]</option>
                            <option value="pig">@L["SimCreate_Species_Pig"]</option>
                            <option value="cow">@L["SimCreate_Species_Cow"]</option>
                            <option value="rabbit">@L["SimCreate_Species_Rabbit"]</option>
                            <option value="fox">@L["SimCreate_Species_Fox"]</option>
                            <option value="bird">@L["SimCreate_Species_Bird"]</option>
                            <option value="mixed">@L["SimCreate_Species_Mixed"]</option>
                        </select>
                    </div>

                    <div class="gx-field">
                        <label class="gx-label" for="BaseModelId">@L["SimCreate_BaseModel_Label"]</label>
                        <select class="gx-select" name="BaseModelId" id="BaseModelId">
                            <option value="">@L["SimCreate_BaseModel_Placeholder"]</option>
                            @foreach (var m in (Model.Models ?? new List<CreatePopulationViewModel.ModelOption>()))
                            {
                                <option value="@m.Id" selected="@(Model?.BaseModelId == m.Id)">
                                    @m.Name (@m.Length bp)
                                </option>
                            }
                        </select>
                        <span class="gx-val" asp-validation-for="BaseModelId"></span>
                    </div>
                </div>

                <div class="gx-divider"></div>

                <div class="gx-simform__section">
                    <div class="gx-simform__sectionTitle">@L["SimCreate_InitialEnvironment_Title"]</div>
                    <div class="gx-simsliders">
                        <div class="gx-slider">
                            <div class="gx-slider__top">
                                <label class="gx-label" asp-for="Temperature">@L["SimCreate_Temperature_Label"]</label>
                                <div class="gx-chip mono"><span id="vTemp">@Model.Temperature</span>°C</div>
                            </div>
                            <input class="gx-range" asp-for="Temperature" type="range" min="-20" max="60" step="1" id="tempRange" />
                        </div>

                        <div class="gx-slider">
                            <div class="gx-slider__top">
                                <label class="gx-label" asp-for="Radiation">@L["SimCreate_Radiation_Label"]</label>
                                <div class="gx-chip mono" id="vRad">@Model.Radiation</div>
                            </div>
                            <input class="gx-range" asp-for="Radiation" type="range" min="0" max="1" step="0.01" id="radRange" />
                        </div>

                        <div class="gx-slider">
                            <div class="gx-slider__top">
                                <label class="gx-label" asp-for="DiseasePressure">@L["SimCreate_DiseasePressure_Label"]</label>
                                <div class="gx-chip mono" id="vDis">@Model.DiseasePressure</div>
                            </div>
                            <input class="gx-range" asp-for="DiseasePressure" type="range" min="0" max="1" step="0.01" id="disRange" />
                        </div>

                        <div class="gx-slider">
                            <div class="gx-slider__top">
                                <label class="gx-label" asp-for="Resources">@L["SimCreate_Resources_Label"]</label>
                                <div class="gx-chip mono" id="vRes">@Model.Resources</div>
                            </div>
                            <input class="gx-range" asp-for="Resources" type="range" min="0" max="1" step="0.01" id="resRange" />
                        </div>
                    </div>
                </div>

                <div class="gx-simform__actions">
                    <button class="gx-btn gx-btn--primary gx-btn--lg" type="submit">
                        @L["SimCreate_StartSimulation_Button"]
                    </button>
                    <div class="gx-muted">@L["SimCreate_LiveEnvironment_Note"]</div>
                </div>
            </form>

            <aside class="gx-card gx-simside">
                <div class="gx-simside__hd">
                    <div class="gx-simside__kicker">@L["SimCreate_Tip_Kicker"]</div>
                    <div class="gx-simside__title">@L["SimCreate_Tip_Title"]</div>
                </div>

                <div class="gx-simside__body">
                    <ul class="gx-ul">
                        <li>@L["SimCreate_Tip_Line1"]</li>
                        <li>@L["SimCreate_Tip_Line2"]</li>
                        <li>@L["SimCreate_Tip_Line3"]</li>
                    </ul>
                    <div class="gx-note">
                        @L["SimCreate_Tip_Note"]
                    </div>
                </div>
            </aside>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        (function(){
          const bind = (id, out, fmt) => {
            const el = document.getElementById(id);
            const o = document.getElementById(out);
            if(!el || !o) return;
            const render = ()=> o.textContent = fmt ? fmt(el.value) : el.value;
            el.addEventListener("input", render);
            render();
          };
          bind("tempRange","vTemp", v=>String(v));
          bind("radRange","vRad", v=>Number(v).toFixed(2));
          bind("disRange","vDis", v=>Number(v).toFixed(2));
          bind("resRange","vRes", v=>Number(v).toFixed(2));
        })();
    </script>
}
