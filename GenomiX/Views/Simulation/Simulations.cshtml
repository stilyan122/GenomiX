@model IEnumerable<PopulationViewModel>
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer L

@{
    ViewData["Title"] = L["SimIndex_PageTitle"];
    ViewData["ActiveNav"] = "simulations";
}

<section class="gx-sim-page">
    <div class="container container--wide gx-sim">

        <header class="gx-sim__header gx-sim__header--index">
            <div class="gx-sim__head-left">
                <div class="gx-sim__kicker">@L["SimIndex_Kicker_Simulations"]</div>
                <h1 class="gx-sim__title">@L["SimIndex_Title"]</h1>
                <p class="gx-sim__subtitle">@L["SimIndex_Subtitle"]</p>
            </div>

            <div class="gx-sim__head-right gx-sim__head-right--index">
                <a class="gx-btn gx-btn--primary gx-sim__cta" href="/simulations/create">
                    <span class="gx-cta__plus">＋</span>
                    @L["SimIndex_Btn_CreateSimulation"]
                </a>
            </div>
        </header>

        @if (Model == null || !Model.Any())
        {
            <div class="gx-empty gx-empty--sim">
                <div class="gx-empty__badge">@L["SimIndex_Empty_Badge"]</div>
                <div class="gx-empty__title">@L["SimIndex_Empty_Title"]</div>
                <div class="gx-empty__text">@L["SimIndex_Empty_Text"]</div>
                <a class="gx-btn gx-btn--primary" href="/simulations/create">@L["SimIndex_Btn_CreateSimulation"]</a>
            </div>
        }
        else
        {
            <div class="gx-sim__toolbar">
                <div class="gx-sim__count">
                    <span class="gx-dot"></span>
                    <strong>@Model.Count()</strong> @L["SimIndex_Runs_Label"]
                </div>
                <div class="gx-sim__legend">
                    <span class="gx-pill gx-pill--soft">@L["SimIndex_Legend_Organisms"]</span>
                    <span class="gx-pill gx-pill--soft">@L["SimIndex_Legend_Environment"]</span>
                    <span class="gx-pill gx-pill--soft">@L["SimIndex_Legend_Ticks"]</span>
                </div>
            </div>

            <div class="gx-simgrid">
                @foreach (var p in Model)
                {
                    var orgCount = p.Organisms?.Count ?? 0;

                    <article class="gx-simtile">
                        <div class="gx-simtile__glow"></div>

                        <header class="gx-simtile__top">
                            <div class="gx-simtile__title">@p.Name</div>
                            <div class="gx-simtile__meta">
                                <span class="gx-meta__k">@L["SimIndex_Created_Label"]</span>
                                <span class="gx-meta__v mono">@p.CreatedAt</span>
                            </div>
                        </header>

                        <div class="gx-simtile__stats">
                            <div class="gx-stat">
                                <div class="gx-stat__k">@L["SimIndex_Stat_Organisms"]</div>
                                <div class="gx-stat__v mono">@orgCount</div>
                                <div class="gx-stat__bar">
                                    <div class="gx-stat__fill" style="width:@(Math.Min(100, 12 + orgCount / 50.0 * 88).ToString("0"))%"></div>
                                </div>
                            </div>
                            <div class="gx-stat">
                                <div class="gx-stat__k">@L["SimIndex_Stat_BaseModel"]</div>
                                <div class="gx-stat__v mono">@p.BaseModelName</div>
                                <div class="gx-stat__hint">@L["SimIndex_Stat_BaseModel_Hint"]</div>
                            </div>
                        </div>

                        @* 2-column action grid: primary action spans full width on top,
                           secondary actions in a row below *@
                        <div class="gx-simtile__actions gx-simtile__actions--grid">
                            <a class="gx-btn gx-btn--primary gx-btn--full" href="/simulations/run/@p.Id">
                                @L["SimIndex_Btn_OpenLab"]
                            </a>

                            <div class="gx-simtile__actions-row">
                                <a class="gx-btn gx-btn--ghost" href="/dna/builder/@p.BaseModelId">@L["SimIndex_Btn_ViewDNA"]</a>
                                <a class="gx-btn gx-btn--ghost" href="/simulations/edit/@p.Id">@L["SimIndex_Btn_Edit"]</a>
                                <form method="post" action="/simulations/delete/@p.Id" style="display:contents"
                                      onsubmit="return confirm('@L["SimIndex_DeleteConfirm"]');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="gx-btn gx-btn--danger">@L["SimIndex_Btn_Delete"]</button>
                                </form>
                            </div>
                        </div>

                    </article>
                }
            </div>
        }
    </div>
</section>
