@model PopulationViewModel

@{
    ViewData["Title"] = "Run simulation";
    ViewData["ActiveNav"] = "simulations";
}

<section class="gx-sim-page gx-runpage">
    <div class="container container--wide gx-sim" id="sim-root" data-pop-id="@Model.Id">

        <header class="gx-runhdr">
            <div class="gx-runhdr__left">
                <div class="gx-sim__kicker">Simulation</div>
                <h1 class="gx-runhdr__title">@Model.Name</h1>
                <div class="gx-runhdr__sub">
                    Live environment control • <span class="mono">DNA</span>
                    <span class="mono">@((Model.BaseModelName ?? Model.BaseModelId?.ToString().Substring(0, 8)) ?? "—")</span>
                    • <span class="mono">Run</span> <span class="mono">@Model.Id.ToString().Substring(0, 8)</span>
                </div>
            </div>

            <div class="gx-runhdr__right">
                <a class="gx-btn gx-btn--ghost" href="/simulations">Back</a>

                <button class="gx-btn gx-btn--primary" id="sim-run" type="button">Start</button>
                <button class="gx-btn" id="sim-step" type="button">Tick ×10</button>
                <button class="gx-btn gx-btn--ghost" id="sim-pause" type="button" disabled>Pause</button>
            </div>

            <div class="gx-runhdr__scenario">
                <select class="gx-select gx-select--sm" id="gx-scenario">
                    <option value="">Scenario…</option>
                </select>

                <button type="button" class="gx-btn gx-btn--ghost" id="gx-scenario-apply">
                    Apply
                </button>
            </div>
        </header>

        <div class="gx-rungrid">
            <main class="gx-card gx-runmain">
                <div class="gx-runmain__top">
                    <div class="gx-hud">
                        <div class="gx-hudchip">
                            <div class="gx-hudchip__k">Alive</div>
                            <div class="gx-hudchip__v mono" id="v-alive">@(@Model.Organisms?.Count ?? 0)</div>
                        </div>

                        <div class="gx-hudchip">
                            <div class="gx-hudchip__k">Dead</div>
                            <div class="gx-hudchip__v mono" id="v-dead">0</div>
                        </div>

                        <div class="gx-hudchip">
                            <div class="gx-hudchip__k">Reproduced</div>
                            <div class="gx-hudchip__v mono" id="v-rep">0</div>
                        </div>

                        <div class="gx-hudchip">
                            <div class="gx-hudchip__k">Avg fitness</div>
                            <div class="gx-hudchip__v mono" id="v-avg">0.000</div>
                        </div>

                        <div class="gx-hudchip">
                            <div class="gx-hudchip__k">Tick</div>
                            <div class="gx-hudchip__v mono" id="v-tick">0</div>
                        </div>
                    </div>

                    <div class="gx-statusrow">
                        <div class="gx-statusdot"></div>
                        <div class="gx-status" id="sim-status">Ready.</div>
                    </div>
                </div>

                <div class="gx-runmain__body">
                    <div class="gx-popcanvas" id="gx-pop-canvas">
                        <canvas id="sim-canvas"></canvas>

                        <button type="button" class="gx-canvasfs" id="gx-canvasfs">
                            Fullscreen
                        </button>
                    </div>

                    <script id="sim-seed" type="application/json">
                        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new {
                          organisms = Model.Organisms.Select(o => new {
                            id = o.Id,
                            name = o.SimpleName,
                            sci = o.ScientificName,
                            status = o.Status,
                            fitness = o.SurvivalScore,
                            species = o.Species
                          })
                        }))
                    </script>

                    <div class="gx-runlog" id="gx-run-log">
                        <div class="gx-runlog__title">Live log</div>
                        <div class="gx-runlog__body" id="gx-run-logBody">
                            <div class="gx-logline">Ready.</div>
                        </div>
                    </div>
                </div>
            </main>

            <aside class="gx-card gx-runside">
                @Html.AntiForgeryToken()

                <div class="gx-runside__hd">
                    <div class="gx-sim__kicker">Environment</div>

                    <div class="gx-runside__hdrow">
                        <div>
                            <div class="gx-runside__title">Control panel</div>
                            <div class="gx-muted">Changes apply live (no reload).</div>
                        </div>
                        <button type="button" class="gx-envtoggle" id="gx-envtoggle" aria-label="Toggle environment panel">⇤</button>
                    </div>
                </div>

                <div class="gx-runside__scroll">
                    <div class="gx-simsliders gx-simsliders--run">
                        <div class="gx-slider">
                            <div class="gx-slider__top">
                                <div class="gx-label">Temperature</div>
                                <div class="gx-chip mono"><span id="out-temp">0</span>°C</div>
                            </div>
                            <input class="gx-range" id="f-temp" type="range" min="-20" max="60" step="1" value="@Model.Temperature" />
                        </div>

                        <div class="gx-slider">
                            <div class="gx-slider__top">
                                <div class="gx-label">Radiation</div>
                                <div class="gx-chip mono" id="out-rad">0.00</div>
                            </div>
                            <input class="gx-range" id="f-rad" type="range" min="0" max="1" step="0.01" value="@Model.Radiation" />
                        </div>

                        <div class="gx-slider">
                            <div class="gx-slider__top">
                                <div class="gx-label">Disease pressure</div>
                                <div class="gx-chip mono" id="out-dis">0.00</div>
                            </div>
                            <input class="gx-range" id="f-dis" type="range" min="0" max="1" step="0.01" value="@Model.DiseasePressure" />
                        </div>

                        <div class="gx-slider">
                            <div class="gx-slider__top">
                                <div class="gx-label">Resources</div>
                                <div class="gx-chip mono" id="out-res">0.00</div>
                            </div>
                            <input class="gx-range" id="f-res" type="range" min="0" max="1" step="0.01" value="@Model.Resources" />
                        </div>

                        <div class="gx-slider">
                            <div class="gx-slider__top">
                                <div class="gx-label">Speed</div>
                                <div class="gx-chip mono" id="out-speed">1</div>
                            </div>
                            <input class="gx-range" id="f-speed" type="range" min="1" max="50" step="1" value="@Model.Speed" />
                        </div>
                    </div>
                </div>
            </aside>
        </div>

    </div>
</section>

@section Scripts {
    <script type="module" src="~/js/simulations/sim-run.js" asp-append-version="true"></script>

    <script>
        (function(){
          const bind = (id, out, fmt) => {
            const el = document.getElementById(id);
            const o = document.getElementById(out);
            if(!el || !o) return;
            const r = ()=> o.textContent = fmt ? fmt(el.value) : el.value;
            el.addEventListener("input", r);
            r();
          };
          bind("f-temp","out-temp", v => String(v));
          bind("f-rad","out-rad", v => Number(v).toFixed(2));
          bind("f-dis","out-dis", v => Number(v).toFixed(2));
          bind("f-res","out-res", v => Number(v).toFixed(2));
          bind("f-speed","out-speed", v => String(v));
        })();
    </script>
}
