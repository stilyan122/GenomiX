@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer L

@{
    ViewData["Title"] = L["PageTitle"];
    ViewData["ActiveNav"] = "home";
}

<section class="home-hero" id="top">
    <div class="container container--wide">
        <div class="home-hero__grid">
            <div class="home-hero__copy reveal reveal--up">
                <div class="badge reveal-item">@L["Hero_Badge"]</div>

                <h1 class="home-h1 reveal-item">
                    @L["Hero_Title"]
                </h1>

                <p class="home-lead reveal-item">
                    @L["Hero_Lead"]
                </p>

                <div class="home-cta reveal-item">
                    <a class="btn primary btn--lg" href="/dna/choose">@L["CTA_StartBuilder"]</a>
                    <a class="btn ghost btn--lg" href="#features">@L["CTA_ExploreModules"]</a>

                    @if (User?.Identity?.IsAuthenticated ?? false)
                    {
                        <a class="btn ghost btn--lg" href="/simulations">@L["CTA_MySimulations"]</a>
                    }
                </div>

                <div class="home-metrics reveal-stagger">
                    <div class="metric reveal-item">
                        <div class="metric__k">@L["Metric_K_2D3D"]</div>
                        <div class="metric__v">@L["Metric_V_Views"]</div>
                    </div>
                    <div class="metric reveal-item">
                        <div class="metric__k">@L["Metric_K_Strict"]</div>
                        <div class="metric__v">@L["Metric_V_Validation"]</div>
                    </div>
                    <div class="metric reveal-item">
                        <div class="metric__k">@L["Metric_K_Roles"]</div>
                        <div class="metric__v">@L["Metric_V_RoleList"]</div>
                    </div>
                </div>

                <p class="home-sub reveal-item" style="margin-top:12px">
                    @L["Hero_ArchLine"]
                </p>
            </div>

            <div class="home-hero__visual reveal reveal--fade" aria-hidden="true">
                <div class="glyph-card reveal-item">
                    <svg class="dna-glyph" viewBox="0 0 520 360" focusable="false">
                        <defs>
                            <linearGradient id="gxStroke" x1="0" y1="0" x2="1" y2="1">
                                <stop offset="0" stop-color="rgba(255,255,255,.55)" />
                                <stop offset="1" stop-color="rgba(255,255,255,.12)" />
                            </linearGradient>
                            <radialGradient id="gxGlow" cx="30%" cy="25%" r="75%">
                                <stop offset="0" stop-color="rgba(81,227,194,.16)" />
                                <stop offset="1" stop-color="rgba(81,227,194,0)" />
                            </radialGradient>
                        </defs>

                        <rect x="0" y="0" width="520" height="360" fill="url(#gxGlow)" opacity=".9" />

                        <path class="helix a" d="M70,70 C160,10 250,110 340,70 C410,40 450,70 470,90" />
                        <path class="helix b" d="M70,290 C160,350 250,250 340,290 C410,320 450,290 470,270" />

                        <g class="rungs">
                            <line x1="120" y1="112" x2="120" y2="248" />
                            <line x1="170" y1="92" x2="170" y2="268" />
                            <line x1="220" y1="90" x2="220" y2="270" />
                            <line x1="270" y1="105" x2="270" y2="255" />
                            <line x1="320" y1="130" x2="320" y2="230" />
                            <line x1="370" y1="155" x2="370" y2="205" />
                            <line x1="420" y1="175" x2="420" y2="185" />
                        </g>

                        <g class="bases">
                            <circle cx="120" cy="112" r="6" />
                            <circle cx="120" cy="248" r="6" />

                            <circle cx="170" cy="92" r="6" />
                            <circle cx="170" cy="268" r="6" />

                            <circle cx="220" cy="90" r="6" />
                            <circle cx="220" cy="270" r="6" />

                            <circle cx="270" cy="105" r="6" />
                            <circle cx="270" cy="255" r="6" />

                            <circle cx="320" cy="130" r="6" />
                            <circle cx="320" cy="230" r="6" />

                            <circle cx="370" cy="155" r="6" />
                            <circle cx="370" cy="205" r="6" />

                            <circle class="mut" cx="420" cy="175" r="7" />
                            <circle cx="420" cy="185" r="6" />
                        </g>
                    </svg>

                    <div class="glyph-caption">
                        <div class="glyph-caption__t">@L["Glyph_T"]</div>
                        <div class="glyph-caption__s">@L["Glyph_S"]</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="home-section reveal reveal--up" id="features">
    <h2 class="home-h2 reveal-item">@L["Sec_Modules_Title"]</h2>
    <p class="home-sub reveal-item">
        @L["Sec_Modules_Sub"]
    </p>

    <div class="tri-grid reveal-stagger">
        <article class="glass-card reveal-item">
            <h3>@L["Card_Builder_T"]</h3>
            <p>@L["Card_Builder_P"]</p>
            <ul class="bullets">
                <li>@L["Card_Builder_L1"]</li>
                <li>@L["Card_Builder_L2"]</li>
                <li>@L["Card_Builder_L3"]</li>
            </ul>
            <a class="card-link" href="/dna/choose">@L["Card_Builder_A"]</a>
        </article>

        <article class="glass-card reveal-item">
            <h3>@L["Card_2D_T"]</h3>
            <p>@L["Card_2D_P"]</p>
            <ul class="bullets">
                <li>@L["Card_2D_L1"]</li>
                <li>@L["Card_2D_L2"]</li>
                <li>@L["Card_2D_L3"]</li>
            </ul>
            <a class="card-link" href="/dna/choose">@L["Card_2D_A"]</a>
        </article>

        <article class="glass-card reveal-item">
            <h3>@L["Card_3D_T"]</h3>
            <p>@L["Card_3D_P"]</p>
            <ul class="bullets">
                <li>@L["Card_3D_L1"]</li>
                <li>@L["Card_3D_L2"]</li>
                <li>@L["Card_3D_L3"]</li>
            </ul>
            <a class="card-link" href="/dna/choose">@L["Card_3D_A"]</a>
        </article>

        <article class="glass-card reveal-item">
            <h3>@L["Card_Sim_T"]</h3>
            <p>@L["Card_Sim_P"]</p>
            <ul class="bullets">
                <li>@L["Card_Sim_L1"]</li>
                <li>@L["Card_Sim_L2"]</li>
                <li>@L["Card_Sim_L3"]</li>
            </ul>
            <a class="card-link" href="/simulations">@L["Card_Sim_A"]</a>
        </article>
    </div>
</section>

<section class="home-section reveal reveal--up" id="workflows">
    <h2 class="home-h2 reveal-item">@L["Sec_Workflows_Title"]</h2>
    <p class="home-sub reveal-item">
        @L["Sec_Workflows_Sub"]
    </p>

    <div class="tri-grid reveal-stagger">
        <article class="glass-card reveal-item">
            <h3>@L["Card_Roles_T"]</h3>
            <p>@L["Card_Roles_P"]</p>
            <ul class="bullets">
                <li>@L["Card_Roles_L1"]</li>
                <li>@L["Card_Roles_L2"]</li>
                <li>@L["Card_Roles_L3"]</li>
            </ul>
        </article>

        <article class="glass-card reveal-item">
            <h3>@L["Card_Lab_T"]</h3>
            <p>@L["Card_Lab_P"]</p>
            <ul class="bullets">
                <li>@L["Card_Lab_L1"]</li>
                <li>@L["Card_Lab_L2"]</li>
                <li>@L["Card_Lab_L3"]</li>
            </ul>
        </article>
    </div>
</section>

<section class="home-section reveal reveal--up" id="how">
    <h2 class="home-h2 reveal-item">@L["Sec_How_Title"]</h2>

    <div class="steps reveal-stagger">
        <div class="step reveal-item">
            <div class="step__n">1</div>
            <div class="step__b">
                <h4>@L["Step1_T"]</h4>
                <p>@L["Step1_P"]</p>
            </div>
        </div>

        <div class="step reveal-item">
            <div class="step__n">2</div>
            <div class="step__b">
                <h4>@L["Step2_T"]</h4>
                <p>@L["Step2_P"]</p>
            </div>
        </div>

        <div class="step reveal-item">
            <div class="step__n">3</div>
            <div class="step__b">
                <h4>@L["Step3_T"]</h4>
                <p>@L["Step3_P"]</p>
            </div>
        </div>

        <div class="step reveal-item">
            <div class="step__n">4</div>
            <div class="step__b">
                <h4>@L["Step4_T"]</h4>
                <p>@L["Step4_P"]</p>
            </div>
        </div>
    </div>
</section>

<section class="home-cta-strip reveal reveal--fade" id="cta">
    <div class="home-cta-strip__inner">
        <div class="reveal-item">
            <h2 class="home-h2">@L["CTA_Title"]</h2>
            <p class="home-sub">
                @L["CTA_Sub"]
            </p>
        </div>
        <div class="home-cta reveal-item">
            <a class="btn primary btn--lg" href="/dna/choose">@L["CTA_OpenBuilder"]</a>
            <a class="btn ghost btn--lg" href="/simulations">@L["CTA_OpenSimulations"]</a>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/js/reveal.js" asp-append-version="true"></script>
}