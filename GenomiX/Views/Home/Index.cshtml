@{
    ViewData["Title"] = "Welcome";
    ViewData["ActiveNav"] = "home";
}

<section class="home-hero" id="top">
    <div class="container container--wide">
        <div class="home-hero__grid">
            <div class="home-hero__copy reveal reveal--up">
                <h1 class="home-h1 reveal-item">Edit DNA in 3D. Watch mutations ripple across life.</h1>
                <p class="home-lead reveal-item">
                    Two-strand editing, instant mutation feedback, and population simulations -
                    all in one place.
                </p>

                <div class="home-cta reveal-item">
                    <a class="btn ghost btn--lg" href="/dna/choose">Start DNA Builder</a>
                    <a class="btn ghost btn--lg" href="#features">Explore features</a>
                </div>

                <div class="home-metrics reveal-stagger">
                    <div class="metric reveal-item">
                        <div class="metric__k">2</div>
                        <div class="metric__v">Core panels</div>
                    </div>
                    <div class="metric reveal-item">
                        <div class="metric__k">2</div>
                        <div class="metric__v">Modes: Basic & Scientific</div>
                    </div>
                </div>
            </div>

            <div class="home-hero__visual reveal reveal--fade" aria-hidden="true">
                <div class="glyph-card reveal-item">
                    <svg class="dna-glyph" viewBox="0 0 520 360" focusable="false">
                        <defs>
                            <linearGradient id="gxStroke" x1="0" y1="0" x2="1" y2="1">
                                <stop offset="0" stop-color="rgba(255,255,255,.55)" />
                                <stop offset="1" stop-color="rgba(255,255,255,.12)" />
                            </linearGradient>
                            <radialGradient id="gxGlow" cx="30%" cy="25%" r="75%">
                                <stop offset="0" stop-color="rgba(81,227,194,.16)" />
                                <stop offset="1" stop-color="rgba(81,227,194,0)" />
                            </radialGradient>
                        </defs>

                        <rect x="0" y="0" width="520" height="360" fill="url(#gxGlow)" opacity=".9" />

                        <path class="helix a" d="M70,70 C160,10 250,110 340,70 C410,40 450,70 470,90" />
                        <path class="helix b" d="M70,290 C160,350 250,250 340,290 C410,320 450,290 470,270" />

                        <g class="rungs">
                            <line x1="120" y1="112" x2="120" y2="248" />
                            <line x1="170" y1="92" x2="170" y2="268" />
                            <line x1="220" y1="90" x2="220" y2="270" />
                            <line x1="270" y1="105" x2="270" y2="255" />
                            <line x1="320" y1="130" x2="320" y2="230" />
                            <line x1="370" y1="155" x2="370" y2="205" />
                            <line x1="420" y1="175" x2="420" y2="185" />
                        </g>

                        <g class="bases">
                            <circle cx="120" cy="112" r="6" />
                            <circle cx="120" cy="248" r="6" />

                            <circle cx="170" cy="92" r="6" />
                            <circle cx="170" cy="268" r="6" />

                            <circle cx="220" cy="90" r="6" />
                            <circle cx="220" cy="270" r="6" />

                            <circle cx="270" cy="105" r="6" />
                            <circle cx="270" cy="255" r="6" />

                            <circle cx="320" cy="130" r="6" />
                            <circle cx="320" cy="230" r="6" />

                            <circle cx="370" cy="155" r="6" />
                            <circle cx="370" cy="205" r="6" />

                            <circle class="mut" cx="420" cy="175" r="7" />
                            <circle cx="420" cy="185" r="6" />
                        </g>
                    </svg>

                    <div class="glyph-caption">
                        <div class="glyph-caption__t">One model</div>
                        <div class="glyph-caption__s">Builder • Simulations • AI Learning</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="home-section reveal reveal--up" id="features">
    <h2 class="home-h2 reveal-item">Two panels. One mental model.</h2>
    <p class="home-sub reveal-item">Build, simulate, and learn - without switching tools.</p>

    <div class="tri-grid reveal-stagger">
        <article class="glass-card reveal-item">
            <h3>DNA Builder</h3>
            <p>Design sequences and apply mutations with instant visual feedback.</p>
            <ul class="bullets">
                <li>Two-strand editing</li>
                <li>Basic & Scientific modes</li>
                <li>Mutation timeline</li>
            </ul>
            <a class="card-link" href="/dna/choose">Open Builder →</a>
        </article>

        <article class="glass-card reveal-item">
            <h3>Simulations</h3>
            <p>See how edits change repair pathways and populations over time.</p>
            <ul class="bullets">
                <li>DNA repair visualization</li>
                <li>Population evolution</li>
                <li>Disease mapping (planned)</li>
            </ul>
            <a class="card-link" href="/simulations">Explore Simulations →</a>
        </article>
    </div>
</section>

<section class="home-section reveal reveal--up" id="how">
    <h2 class="home-h2 reveal-item">How it works</h2>

    <div class="steps reveal-stagger">
        <div class="step reveal-item">
            <div class="step__n">1</div>
            <div class="step__b">
                <h4>Create</h4>
                <p>Start from templates or build DNA from scratch.</p>
            </div>
        </div>
        <div class="step reveal-item">
            <div class="step__n">2</div>
            <div class="step__b">
                <h4>Edit</h4>
                <p>Insert, delete, substitute - watch effects instantly.</p>
            </div>
        </div>
 
    </div>
</section>

<section class="home-cta-strip reveal reveal--fade" id="cta">
    <div class="home-cta-strip__inner">
        <div class="reveal-item">
            <h2 class="home-h2">Ready to experiment?</h2>
            <p class="home-sub">Open the DNA Builder demo or check out your simulations for stimulating learning.</p>
        </div>
        <div class="home-cta reveal-item">
            <a class="btn ghost btn--lg" href="/dna">Open DNA Builder</a>
            <a class="btn ghost btn--lg" href="/simulations">Open Simulations</a>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/js/reveal.js" asp-append-version="true"></script>
}