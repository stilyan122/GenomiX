<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GenomiX</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/vars.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/base.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dna.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dna-science.css" asp-append-version="true" />
</head>
<body>
    <header class="wrap">
        <nav class="nav" aria-label="Main">
            <div class="brand">
                <div class="logo" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" width="18" height="18">
                        <path d="M6 4c6 0 6 16 12 16" stroke="#0b1020" stroke-width="2" opacity=".6" />
                        <path d="M6 20c6 0 6-16 12-16" stroke="#0b1020" stroke-width="2" />
                    </svg>
                </div>
                <strong>GenomiX</strong>
            </div>

            <div class="navlinks">
                <a href="#features">Features</a>
                <a href="#how">How it works</a>
                <a href="#cta">Get started</a>
                <a class="btn ghost" href="/dna/choose">Open demo</a>
            </div>

            <div class="auth">
                <partial name="_LoginPartial" />
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div>© @DateTime.UtcNow.Year GenomiX. Built for learning genetics.</div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script type="module" src="~/js/dna-builder.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
