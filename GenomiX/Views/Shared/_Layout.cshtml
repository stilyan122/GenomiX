<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GenomiX</title>

    <link rel="icon" href="~/images/icons/favicon.ico" sizes="any">
    <link rel="icon" type="image/png" sizes="32x32" href="~/images/icons/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="~/images/icons/favicon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="~/images/icons/apple-touch-icon.png">

    <link rel="stylesheet" href="~/css/dna/dna.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/core/core.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/simulations/sim.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header class="wrap">
        <div class="wrap__inner">
            <nav class="nav" aria-label="Main">
                <a class="brand" href="/">
                    <img src="~/images/brand/gx-logo.png" alt="GenomiX" class="brand__logo" />
                    <strong>GenomiX</strong>
                </a>

                <div class="navlinks navlinks--primary">
                    <a class="navlink @(ViewData["ActiveNav"] as string == "dna" ? "is-active" : "")" href="/dna">DNA Builder</a>
                    <a class="navlink @(ViewData["ActiveNav"] as string == "sim" ? "is-active" : "")" href="/simulations">Simulations</a>
                    <a class="navlink @(ViewData["ActiveNav"] as string == "ai" ? "is-active" : "")" href="/learning">AI Learning</a>
                </div>

                <div class="auth">
                    <partial name="_LoginPartial" />
                </div>
            </nav>
        </div>
    </header>


    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer">
        <div class="container">
            <div class="footer-bar">
                <nav class="footer-nav" aria-label="Footer">
                    <a href="/dna">DNA Builder</a>
                    <a href="/simulations">Simulations</a>
                    <a href="/learning">AI Learning</a>
                </nav>

                <div class="footer-copy">© @DateTime.UtcNow.Year GenomiX - Built for learning genetics</div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script type="module" src="~/js/reveal.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
