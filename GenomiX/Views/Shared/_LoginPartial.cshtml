@using GenomiX.Infrastructure.Models
@using Microsoft.AspNetCore.Identity
@inject SignInManager<GenUser> SignInManager

<ul class="auth-nav" role="list">
    @if (SignInManager.IsSignedIn(User))
    {
        <li>
            <a class="btn ghost btn--sm" asp-area="Identity" asp-page="/Account/Manage/Index">Account</a>
        </li>

        <li>
            <form class="auth-nav__logout" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="~/" method="post">
                <button type="submit" class="btn ghost btn--sm btn-logout">Log out</button>
            </form>
        </li>
    }
    else
    {
        <li>
            <a class="btn ghost btn--sm" asp-area="Identity" asp-page="/Account/Login">Log in</a>
        </li>
        <li>
            <a class="btn ghost btn--sm" asp-area="Identity" asp-page="/Account/Register">Register</a>
        </li>
    }
</ul>
