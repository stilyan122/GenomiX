@inject IViewLocalizer Localizer

<div class="auth-wrap">
    <div class="auth-card error-card reveal is-in">

        <div class="error-code">401</div>

        <h1 class="auth-title">@Localizer["Title"]</h1>

        <p class="auth-sub">@Localizer["Message"]</p>

        <div class="auth-external">
            <a href="../Identity/Account/Login" class="btn primary">
                @Localizer["Login"]
            </a>

            <a href="/" class="btn ghost">
                @Localizer["Home"]
            </a>
        </div>

    </div>
</div>