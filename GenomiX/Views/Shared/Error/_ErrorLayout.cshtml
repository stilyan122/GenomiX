<div class="auth-wrap">
    <div class="auth-card error-card reveal is-in">
    
        <div class="error-code">@ViewBag.Code</div>

        <h1 class="auth-title">@ViewBag.Title</h1>

        <p class="auth-sub">
            @ViewBag.Message
        </p>

        <div class="auth-external">
            <a href="/" class="btn primary">Go Home</a>
            <a href="javascript:history.back()" class="btn ghost">Go Back</a>
        </div>

    </div>
</div>