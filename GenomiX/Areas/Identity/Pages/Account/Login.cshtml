@page
@model GenomiX.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Sign in";
}

<div class="auth-wrap">
    <div class="auth-card">
        <h1 class="auth-title">Sign in</h1>
        <p class="auth-sub">Welcome back to GenomiX.</p>

        <form id="loginForm" method="post" class="auth-form" novalidate>
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="auth-validation" role="alert"></div>

            <div class="auth-field">
                <label class="auth-label" asp-for="Input.EmailOrUserName">Email</label>
                <input class="auth-input" asp-for="Input.EmailOrUserName" autocomplete="username" placeholder="your-email@example.com" />
                <span class="auth-error" asp-validation-for="Input.EmailOrUserName"></span>
            </div>

            <div class="auth-field">
                <label class="auth-label" asp-for="Input.Password">Password</label>
                <input class="auth-input" asp-for="Input.Password" autocomplete="current-password" placeholder="••••••••" />
                <span class="auth-error" asp-validation-for="Input.Password"></span>
            </div>

            <button id="login-submit" type="submit" class="auth-button">Sign in</button>

            <div class="auth-foot">
                <a id="forgot-password" class="auth-link" asp-page="./ForgotPassword">Forgot password?</a>
                <a class="auth-link" asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create account</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
