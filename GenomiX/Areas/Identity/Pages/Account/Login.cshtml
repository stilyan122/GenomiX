@page
@using Microsoft.AspNetCore.Authentication
@model GenomiX.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Sign in";

    var allowed = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
    { "google", "facebook", "github" };

    var providers = ((List<AuthenticationScheme>)Model.ExternalLogins ?? new List<AuthenticationScheme>())
        .Where(p => allowed.Contains(p.Name ?? ""))
        .ToList();
}

<div class="auth-wrap">
    <div class="auth-card">
        <h1 class="auth-title"><span data-i18n="Login_Title">Log in your account</span></h1>
        <p class="auth-sub"><span data-i18n="Login_Welcome">Welcome back to GenomiX.</span></p>

        <form id="loginForm" method="post" class="auth-form" novalidate>
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="auth-validation" role="alert"></div>

            <div class="auth-field">
                <label class="auth-label" asp-for="Input.EmailOrUserName"><span data-i18n="Login_EmailOrUser">Email or username</span></label>
                <input class="auth-input"
                       asp-for="Input.EmailOrUserName"
                       autocomplete="username"
                       placeholder="your-email@example.com or username" />
                <span class="auth-error" asp-validation-for="Input.EmailOrUserName"></span>
            </div>

            <div class="auth-field">
                <label class="auth-label" asp-for="Input.Password"><span data-i18n="Tab_Password">Password</span></label>
                <input class="auth-input"
                       asp-for="Input.Password"
                       type="password"
                       autocomplete="current-password"
                       placeholder="••••••••" />
                <span class="auth-error" asp-validation-for="Input.Password"></span>
            </div>

            <div class="auth-foot auth-foot--spread">
                <label class="auth-remember">
                    <input class="auth-remember__input" asp-for="Input.RememberMe" />
                    <span class="auth-remember__box" aria-hidden="true"></span>
                    <span class="auth-remember__text"><span data-i18n="Login_Remember">Remember me</span></span>
                </label>

                <div class="auth-links">
                    <a id="forgot-password" class="link" asp-page="./ForgotPassword"><span data-i18n="Login_Forgot">Forgot password?</span></a>
                    <span class="auth-dot">·</span>
                    <a class="link" asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl"><span data-i18n="Login_Create">Create account</span></a>
                </div>
            </div>

            <button id="login-submit" type="submit" class="auth-button"><span data-i18n="Login_SignIn">Sign in</span></button>
        </form>

        @if (providers.Count > 0)
        {
            <div class="auth-sep">
                <div class="auth-sep-line"></div>
                <div class="auth-sep-text"><span data-i18n="Login_Or">or</span></div>
                <div class="auth-sep-line"></div>
            </div>

            <form asp-page="./ExternalLogin"
                  asp-route-returnUrl="@Model.ReturnUrl"
                  method="post"
                  class="ext-login">
                @Html.AntiForgeryToken()

                @foreach (var provider in providers)
                {
                    var name = (provider.Name ?? "").ToLowerInvariant();
                    var btnClass = name switch
                    {
                        "google" => "btn-google",
                        "facebook" => "btn-facebook",
                        "github" => "btn-github",
                        _ => "btn-neutral"
                    };

                    <button type="submit"
                            class="btn-ext @btnClass"
                            name="provider"
                            value="@provider.Name"
                            title="Login with @provider.DisplayName">
                        <span class="ico">
                            @if (name == "google")
                            {
                                @:
                                <svg viewBox="0 0 48 48" aria-hidden="true"><path fill="#EA4335" d="M24 9.5c3.2 0 6.1 1.1 8.4 3.2l6.2-6.2C34.9 2.5 29.8 .5 24 .5 14.8.5 6.8 5.9 3.2 13.6l7.3 5.7C12.3 13.7 17.7 9.5 24 9.5z" /><path fill="#4285F4" d="M46.5 24.5c0-1.7-.2-3.4-.6-5H24v9.5h12.7c-.6 3.1-2.4 5.8-5.1 7.6l7.9 6.1c4.6-4.2 7-10.4 7-18.2z" /><path fill="#FBBC05" d="M10.5 28.9c-.6-1.9-.9-3.9-.9-5.9s.3-4 .9-5.9l-7.3-5.7C1.1 14 0 18.9 0 23s1.1 9 3.2 12.6l7.3-6.7z" /><path fill="#34A853" d="M24 46.5c6.4 0 11.8-2.1 15.7-5.7l-7.9-6.1c-2.2 1.5-5.1 2.4-7.8 2.4-6.3 0-11.7-4.2-13.5-10.1l-7.3 6.7C6.8 42.1 14.8 46.5 24 46.5z" /></svg>
                            }
                            else if (name == "facebook")
                            {
                                @:
                                <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="#1877F2" d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078V12.07h3.047V9.412c0-3.007 1.792-4.668 4.533-4.668 1.313 0 2.686.235 2.686.235v2.953h-1.515c-1.492 0-1.955.927-1.955 1.878v2.26h3.328l-.532 3.493h-2.796V24C19.612 23.094 24 18.1 24 12.073z" /></svg>
                            }
                            else if (name == "github")
                            {
                                @:
                                <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="#fff" d="M12 .5C5.73.5.99 5.23.99 11.5c0 4.86 3.15 8.98 7.52 10.43.55.1.75-.24.75-.53 0-.26-.01-1.1-.02-1.99-3.06.66-3.7-1.3-3.7-1.3-.5-1.27-1.22-1.61-1.22-1.61-.99-.67.07-.66.07-.66 1.1.08 1.67 1.12 1.67 1.12.98 1.67 2.58 1.19 3.2.91.1-.71.38-1.19.69-1.46-2.44-.28-5-1.22-5-5.43 0-1.2.43-2.18 1.13-2.95-.11-.28-.49-1.42.11-2.96 0 0 .93-.3 3.05 1.13a10.5 10.5 0 0 1 5.56 0c2.12-1.43 3.05-1.13 3.05-1.13.6 1.54.22 2.68.11 2.96.7.77 1.13 1.75 1.13 2.95 0 4.22-2.57 5.14-5.02 5.41.39.33.74.97.74 1.96 0 1.42-.01 2.57-.01 2.92 0 .29.2.64.76.53A10.99 10.99 0 0 0 23 11.5C23 5.23 18.27.5 12 .5z" /></svg>
                            }
                        </span>

                        <span>Login with @provider.DisplayName</span>
                    </button>
                }
            </form>
        }
    
    
    </div>
</div>

@section Scripts {
    <script src="~/js/identity-i18n.js" asp-append-version="true"></script>
<partial name="_ValidationScriptsPartial" />
}
