@page
@model ConfirmEmailModel
@{
    ViewData["Title"] = "Email confirmed";
}

<div class="auth-wrap">
    <div class="auth-card">
        <h1 class="auth-title">Email confirmed ✅</h1>

        @if (Model.StatusMessage != null)
        {
            <p class="auth-sub">@Model.StatusMessage</p>
        }
        else
        {
            <p class="auth-sub">Your email is confirmed. You can sign in now.</p>
        }

        <div class="auth-foot">
            <a class="auth-link" asp-page="./Login">Go to sign in</a>
        </div>
    </div>
</div>
