@page
@model ExternalLoginModel
@{
    ViewData["Title"] = "Finish registration";
}

<div class="auth-wrap">
    <div class="auth-card">
        <h1 class="auth-title">Finish registration</h1>
        <p class="auth-sub">
            You signed in with <strong>@Model.ProviderDisplayName</strong>. Complete your profile to continue.
        </p>

        <form asp-page-handler="Confirmation"
              asp-route-returnUrl="@Model.ReturnUrl"
              method="post"
              class="auth-form"
              novalidate>

            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="auth-validation" role="alert"></div>

            <div class="auth-field">
                <label class="auth-label" asp-for="Input.Email">Email</label>
                <input class="auth-input" asp-for="Input.Email" autocomplete="email" placeholder="your-email@example.com" />
                <span class="auth-error" asp-validation-for="Input.Email"></span>
            </div>

            <div class="auth-field">
                <label class="auth-label" asp-for="Input.FirstName">First name</label>
                <input class="auth-input" asp-for="Input.FirstName" autocomplete="given-name" placeholder="John" />
                <span class="auth-error" asp-validation-for="Input.FirstName"></span>
            </div>

            <div class="auth-field">
                <label class="auth-label" asp-for="Input.LastName">Last name</label>
                <input class="auth-input" asp-for="Input.LastName" autocomplete="family-name" placeholder="Doe" />
                <span class="auth-error" asp-validation-for="Input.LastName"></span>
            </div>

            <button type="submit" class="auth-button">Create account</button>

            <div class="auth-foot">
                <a class="auth-link" asp-page="./Login">Back to sign in</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
