@page
@model ExternalLoginModel
@{
    ViewData["Title"] = "Finish registration";
}

<div class="auth-wrap">
    <div class="auth-card">
        <h1 class="auth-title"><span data-i18n="Ext_FinishReg">Finish registration</span></h1>
        <p class="auth-sub">
            <span data-i18n="Ext_SignedInWith_Pre">You signed in with </span><strong>@Model.ProviderDisplayName</strong><span data-i18n="Ext_SignedInWith_Post">. Complete your profile to continue.</span>
        </p>

        <form asp-page-handler="Confirmation"
              asp-route-returnUrl="@Model.ReturnUrl"
              method="post"
              class="auth-form"
              novalidate>

            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="auth-validation" role="alert"></div>

            <div class="auth-field">
                <label class="auth-label" asp-for="Input.Email"><span data-i18n="Lbl_Email">Email</span></label>
                <input class="auth-input" asp-for="Input.Email" autocomplete="email" placeholder="your-email@example.com" />
                <span class="auth-error" asp-validation-for="Input.Email"></span>
            </div>

            <div class="auth-field">
                <label class="auth-label" asp-for="Input.FirstName"><span data-i18n="Lbl_FirstName">First name</span></label>
                <input class="auth-input" asp-for="Input.FirstName" autocomplete="given-name" placeholder="John" />
                <span class="auth-error" asp-validation-for="Input.FirstName"></span>
            </div>

            <div class="auth-field">
                <label class="auth-label" asp-for="Input.LastName"><span data-i18n="Lbl_LastName">Last name</span></label>
                <input class="auth-input" asp-for="Input.LastName" autocomplete="family-name" placeholder="Doe" />
                <span class="auth-error" asp-validation-for="Input.LastName"></span>
            </div>

            <button type="submit" class="auth-button"><span data-i18n="Ext_CreateAccount">Create account</span></button>

            <div class="auth-foot">
                <a class="auth-link" asp-page="./Login"><span data-i18n="Ext_BackLogin">Back to sign in</span></a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/identity-i18n.js" asp-append-version="true"></script>
<partial name="_ValidationScriptsPartial" />
}
