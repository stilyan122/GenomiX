@page
@model ForgotPasswordConfirmation
@{
    ViewData["Title"] = "Password reset link sent";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}

<div class="gx-auth">
    <div class="gx-card">
        <div class="gx-head">
            <div class="gx-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="24" height="24" role="img">
                    <path d="M3 5h18a1 1 0 0 1 1 1v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a1 1 0 0 1 1-1zm0 2v.2l9 5.4 9-5.4V7l-9 5.4L3 7z" fill="currentColor" opacity=".9" />
                    <path d="M16.8 9.6a.9.9 0 0 1 1.27.02l.02.02a.9.9 0 0 1 0 1.28l-5 5a.9.9 0 0 1-1.28 0l-2.5-2.5a.9.9 0 0 1 1.28-1.28l1.86 1.86 4.35-4.4z" fill="currentColor" />
                </svg>
            </div>
            <div>
                <h1 class="gx-title"><span data-i18n="FPConf_Title">Check your email</span></h1>
                <p class="gx-sub"><span data-i18n="FPConf_Sub">We’ve sent a link to reset your password.</span></p>
            </div>
        </div>

        <p class="gx-lead">
            If an account exists with the email you entered, you'll receive a message with instructions to set a new password.
            The link expires after a short time, so be quick!
        </p>

        <div class="gx-actions">
            <a class="gx-btn gx-btn-primary" asp-area="" asp-controller="Home" asp-action="Index"><span data-i18n="FPConf_BackHome">Back to Home</span></a>
            <a class="gx-btn gx-btn-ghost" asp-page="./Login"><span data-i18n="FPConf_BackLogin">Return to Login</span></a>
        </div>

        <hr class="gx-divider" />

        <p class="gx-hint">
            <span data-i18n="FPConf_DidntGet">Didn’t get the email? Check spam, or </span><a class="gx-link" asp-page="./ForgotPassword"><span data-i18n="FPConf_TryAgain">try again</span></a><span data-i18n="FPConf_Dot">.</span>
        </p>
    </div>
</div>


<script src="~/js/identity-i18n.js" asp-append-version="true"></script>
