@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Check your email";
}

<div class="auth-wrap">
    <div class="auth-card">
        <h1 class="auth-title"><span data-i18n="RegConf_Title">Check your inbox</span></h1>
        <p class="auth-sub">
            <span data-i18n="RegConf_Sent_Pre">We sent a confirmation email to </span><strong>@Model.Email</strong><span data-i18n="FPConf_Dot">.</span>
            Click the link inside to activate your account.
        </p>

        <hr class="auth-sep-line" style="margin:18px 0;" />

        <p class="auth-sub" style="margin:0;">
            Didn’t receive it? Check Spam/Promotions, or try registering again in a minute.
        </p>

        <div class="auth-foot">
            <a class="auth-link" asp-page="./Login"><span data-i18n="RegConf_BackLogin">Back to sign in</span></a>
            <a class="auth-link" asp-page="./Register"><span data-i18n="RegConf_DiffEmail">Use a different email</span></a>
        </div>
    </div>
</div>


<script src="~/js/identity-i18n.js" asp-append-version="true"></script>
