@page
@model GenomiX.Areas.Identity.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot your password?";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}

<div class="auth-wrap">
    <div class="auth-card">
        <h1 class="auth-title"><span data-i18n="FP_Title">Forgot your password?</span></h1>
        <p class="auth-subtitle"><span data-i18n="FP_Sub">Enter your email and we'll send you a reset link.</span></p>

        <form method="post" novalidate>
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="auth-validation" role="alert"></div>

            <div class="auth-field">
                <label class="auth-label" asp-for="Input.Email"><span data-i18n="Lbl_Email">Email</span></label>
                <input class="auth-input" asp-for="Input.Email" autocomplete="username" placeholder="you@example.com" />
                <span class="auth-error" asp-validation-for="Input.Email"></span>
            </div>

            <button type="submit" class="auth-button"><span data-i18n="FP_SendLink">Send reset link</span></button>

            <div class="auth-foot">
                <span><span data-i18n="FP_Remembered">Remembered it?</span></span>
                <a class="link" asp-area="Identity" asp-page="/Account/Login"><span data-i18n="FP_BackLogin">Back to sign in</span></a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/identity-i18n.js" asp-append-version="true"></script>
<partial name="_ValidationScriptsPartial" />
}
