@page
@model GenomiX.Areas.Identity.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot your password?";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}

<div class="auth-wrap">
    <div class="auth-card">
        <h1 class="auth-title">Forgot your password?</h1>
        <p class="auth-subtitle">Enter your email and we'll send you a reset link.</p>

        <form method="post" novalidate>
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="auth-validation" role="alert"></div>

            <div class="auth-field">
                <label class="auth-label" asp-for="Input.Email">Email</label>
                <input class="auth-input" asp-for="Input.Email" autocomplete="username" placeholder="you@example.com" />
                <span class="auth-error" asp-validation-for="Input.Email"></span>
            </div>

            <button type="submit" class="auth-button">Send reset link</button>

            <div class="auth-foot">
                <span>Remembered it?</span>
                <a class="link" asp-area="Identity" asp-page="/Account/Login">Back to sign in</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
