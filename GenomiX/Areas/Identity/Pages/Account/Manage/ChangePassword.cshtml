@page
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer L

@model GenomiX.Areas.Identity.Pages.Account.Manage.ChangePasswordModel
@{
    ViewData["Title"] = L["Title"];
    Layout = "_ManageShell";
}

<form method="post" class="auth-form" novalidate>
    <div asp-validation-summary="ModelOnly" class="auth-validation" role="alert"></div>

    <div class="auth-field">
        <label class="auth-label" asp-for="Input.OldPassword" data-i18n="Lbl_CurrentPassword">Current Password</label>
        <input class="auth-input" asp-for="Input.OldPassword" type="password" autocomplete="current-password" />
        <span class="auth-error" asp-validation-for="Input.OldPassword"></span>
    </div>

    <div class="auth-field">
        <label class="auth-label" asp-for="Input.NewPassword" data-i18n="Lbl_NewPassword">New Password</label>
        <input class="auth-input" asp-for="Input.NewPassword" type="password" autocomplete="new-password" />
        <span class="auth-error" asp-validation-for="Input.NewPassword"></span>
    </div>

    <div class="auth-field">
        <label class="auth-label" asp-for="Input.ConfirmPassword" data-i18n="Lbl_ConfirmNewPassword">Confirm New Password</label>
        <input class="auth-input" asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password" />
        <span class="auth-error" asp-validation-for="Input.ConfirmPassword"></span>
    </div>

    <button type="submit" class="auth-button" data-i18n="Btn_UpdatePassword">Update Password</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
