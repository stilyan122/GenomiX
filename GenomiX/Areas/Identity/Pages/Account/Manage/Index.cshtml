@page
@model GenomiX.Areas.Identity.Pages.Account.Manage.IndexModel
@{
    ViewData["Title"] = "Account";
    Layout = "_ManageShell";
}

<form method="post" class="auth-form" novalidate>
    <div asp-validation-summary="ModelOnly" class="auth-validation" role="alert"></div>

    <div class="auth-field">
        <label class="auth-label"><span data-i18n="Lbl_Username">Username</span></label>
        <input class="auth-input" value="@Model.Username" disabled />
    </div>

    <div class="auth-field">
        <label class="auth-label" asp-for="Input.FirstName">
            <span data-i18n="Lbl_FirstName">First name</span>
        </label>
        <input class="auth-input" asp-for="Input.FirstName" />
        <span class="auth-error" asp-validation-for="Input.FirstName"></span>
    </div>

    <div class="auth-field">
        <label class="auth-label" asp-for="Input.LastName">
            <span data-i18n="Lbl_LastName">Last name</span>
        </label>
        <input class="auth-input" asp-for="Input.LastName" />
        <span class="auth-error" asp-validation-for="Input.LastName"></span>
    </div>

    <button type="submit" class="auth-button">
        <span data-i18n="Btn_Save">Save</span>
    </button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}