@page
@model GenomiX.Areas.Identity.Pages.Account.Manage.IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<div class="gx-auth gx-auth--dense">
    <div class="gx-card">
        <div class="gx-head">
            <div class="gx-icon">GX</div>
            <div>
                <h1 class="gx-title">Profile</h1>
                <p class="gx-sub">Manage your GenomiX account details.</p>
            </div>
        </div>

        <partial name="_StatusMessage" for="StatusMessage" />

        <partial name="_ManageNav" />

        <hr class="gx-divider" />

        <form method="post" class="auth-form" novalidate>
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="auth-validation" role="alert"></div>

            <div class="auth-field">
                <label class="auth-label">Username</label>
                <input class="auth-input" value="@Model.Username" disabled />
            </div>

            <div class="auth-field">
                <label class="auth-label" asp-for="Input.FirstName">First name</label>
                <input class="auth-input" asp-for="Input.FirstName" autocomplete="given-name" />
                <span class="auth-error" asp-validation-for="Input.FirstName"></span>
            </div>

            <div class="auth-field">
                <label class="auth-label" asp-for="Input.LastName">Last name</label>
                <input class="auth-input" asp-for="Input.LastName" autocomplete="family-name" />
                <span class="auth-error" asp-validation-for="Input.LastName"></span>
            </div>

            <button type="submit" class="auth-button">Save</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
