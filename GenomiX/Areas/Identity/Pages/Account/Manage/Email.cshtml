@page
@model GenomiX.Areas.Identity.Pages.Account.Manage.EmailModel
@{
    ViewData["Title"] = "Email";
    Layout = "_ManageShell";
}

<form method="post" class="auth-form" novalidate>
    <div asp-validation-summary="ModelOnly" class="auth-validation" role="alert"></div>

    <div class="auth-field">
        <label class="auth-label">Current email</label>
        <input class="auth-input" value="@Model.Email" disabled />
    </div>

    <div class="auth-field">
        <label class="auth-label" asp-for="Input.NewEmail">New email</label>
        <input class="auth-input" asp-for="Input.NewEmail" autocomplete="email" />
        <span class="auth-error" asp-validation-for="Input.NewEmail"></span>
    </div>

    <button type="submit" class="auth-button" asp-page-handler="ChangeEmail">
        Send confirmation
    </button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}