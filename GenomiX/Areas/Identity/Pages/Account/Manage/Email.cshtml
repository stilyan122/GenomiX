@page
@model GenomiX.Areas.Identity.Pages.Account.Manage.EmailModel
@{
    ViewData["Title"] = "Email";
    ViewData["ActivePage"] = ManageNavPages.Email;
}

<div class="gx-auth gx-auth--dense">
    <div class="gx-card">
        <div class="gx-head">
            <div class="gx-icon">✉</div>
            <div>
                <h1 class="gx-title">Email</h1>
                <p class="gx-sub">Change your email with confirmation.</p>
            </div>
        </div>

        <partial name="_StatusMessage" for="StatusMessage" />
        <partial name="_ManageNav" />
        <hr class="gx-divider" />

        <form method="post" class="auth-form" novalidate>
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="auth-validation" role="alert"></div>

            <div class="auth-field">
                <label class="auth-label">Current email</label>
                <input class="auth-input" value="@Model.Email" disabled />
                <div class="gx-hint" style="margin-top:6px;">
                    Status: @(Model.IsEmailConfirmed ? "Confirmed ✅" : "Not confirmed ⚠️")
                </div>
            </div>

            <div class="auth-field">
                <label class="auth-label" asp-for="Input.NewEmail">New email</label>
                <input class="auth-input" asp-for="Input.NewEmail" autocomplete="email" placeholder="new-email@example.com" />
                <span class="auth-error" asp-validation-for="Input.NewEmail"></span>
            </div>

            <div class="gx-actions">
                <button type="submit" asp-page-handler="ChangeEmail" class="gx-btn gx-btn-primary">Send confirmation</button>

                @if (!Model.IsEmailConfirmed)
                {
                    <button type="submit" asp-page-handler="SendVerificationEmail" class="gx-btn gx-btn-ghost">
                        Resend current email confirmation
                    </button>
                }
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
