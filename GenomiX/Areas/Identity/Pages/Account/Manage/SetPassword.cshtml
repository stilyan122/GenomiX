@page
@model GenomiX.Areas.Identity.Pages.Account.Manage.SetPasswordModel
@{
    ViewData["Title"] = "Set password";
    ViewData["ActivePage"] = ManageNavPages.SetPassword;
}

<div class="gx-auth gx-auth--dense">
    <div class="gx-card">
        <div class="gx-head">
            <div class="gx-icon">➕</div>
            <div>
                <h1 class="gx-title">Set password</h1>
                <p class="gx-sub">Add a password so you can also sign in with email + password.</p>
            </div>
        </div>

        <partial name="_StatusMessage" for="StatusMessage" />
        <partial name="_ManageNav" />
        <hr class="gx-divider" />

        <form method="post" class="auth-form" novalidate>
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="auth-validation" role="alert"></div>

            <div class="auth-field">
                <label class="auth-label" asp-for="Input.NewPassword"></label>
                <input class="auth-input" asp-for="Input.NewPassword" type="password" autocomplete="new-password" />
                <span class="auth-error" asp-validation-for="Input.NewPassword"></span>
            </div>

            <div class="auth-field">
                <label class="auth-label" asp-for="Input.ConfirmPassword"></label>
                <input class="auth-input" asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password" />
                <span class="auth-error" asp-validation-for="Input.ConfirmPassword"></span>
            </div>

            <button type="submit" class="auth-button">Save</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
