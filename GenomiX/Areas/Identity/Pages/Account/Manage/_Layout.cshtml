@{
    Layout = "/Areas/Identity/Pages/_Layout.cshtml";
}

<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
<link rel="stylesheet" href="~/css/vars.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/base.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/dna.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/dna-science.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />

<div class="auth-wrap">
    <div class="auth-card">
        <h1 class="auth-title">Account</h1>
        <p class="auth-sub">Manage your profile, email and password.</p>

        <div class="manage-grid">
            <nav class="manage-nav" aria-label="Account navigation">
                <partial name="_ManageNav" />
            </nav>

            <section class="manage-content">
                @RenderBody()
            </section>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script type="module" src="~/js/dna-builder.js" asp-append-version="true"></script>

@section Scripts {
    @RenderSection("Scripts", required: false)
}
