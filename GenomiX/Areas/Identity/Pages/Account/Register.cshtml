@page
@model GenomiX.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Create account";
}

<div class="auth-wrap">
    <div class="auth-card">
        <h1 class="auth-title">Create your account</h1>
        <p class="auth-sub">Join GenomiX to build and save your own DNA models.</p>

        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="auth-form" novalidate>
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="auth-validation" role="alert"></div>

            <div class="auth-field">
                <label class="auth-label" asp-for="Input.Email">Email</label>
                <input class="auth-input" asp-for="Input.Email" autocomplete="username" placeholder="your-email@example.com" />
                <span class="auth-error" asp-validation-for="Input.Email"></span>
            </div>

            <div class="auth-field">
                <label class="auth-label" asp-for="Input.FirstName">First name</label>
                <input class="auth-input" asp-for="Input.FirstName" autocomplete="first-name" placeholder="Michael" />
                <span class="auth-error" asp-validation-for="Input.FirstName"></span>
            </div>
            <div class="auth-field">
                <label class="auth-label" asp-for="Input.LastName">Last name</label>
                <input class="auth-input" asp-for="Input.LastName" autocomplete="last-name" placeholder="Smith" />
                <span class="auth-error" asp-validation-for="Input.LastName"></span>
            </div>


            <div class="auth-field">
                <label class="auth-label" asp-for="Input.Password">Password</label>
                <input class="auth-input" asp-for="Input.Password" autocomplete="new-password" placeholder="••••••••" />
                <span class="auth-error" asp-validation-for="Input.Password"></span>
            </div>

            <div class="auth-field">
                <label class="auth-label" asp-for="Input.ConfirmPassword">Confirm password</label>
                <input class="auth-input" asp-for="Input.ConfirmPassword" autocomplete="new-password" placeholder="••••••••" />
                <span class="auth-error" asp-validation-for="Input.ConfirmPassword"></span>
            </div>

            <button id="registerSubmit" type="submit" class="auth-button">Create account</button>

            <div class="auth-foot">
                <span>Already have an account?</span>
                <a class="auth-link" asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="@Model.ReturnUrl">Sign in</a>
            </div>
        </form>

        @if ((Model.ExternalLogins?.Count ?? 0) > 0)
        {
            <div class="auth-sep">
                <span class="auth-sep-line"></span>
                <span class="auth-sep-text">or</span>
                <span class="auth-sep-line"></span>
            </div>
            <form asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="auth-external">
                @foreach (var provider in Model.ExternalLogins!)
                {
                    <button type="submit" name="provider" value="@provider.Name" class="auth-external-btn">
                        Continue with @provider.DisplayName
                    </button>
                }
            </form>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
