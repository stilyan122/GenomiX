@model IReadOnlyList<ReferenceSequenceListItemViewModel>

@{
    ViewData["Title"] = "Lab Sequences";
}

<div class="gx-lab-page">
    <div class="gx-lab-head">
        <div>
            <h1 class="gx-lab-title"><span data-i18n="LabIndex_Title">Lab Sequences</span></h1>
            <div class="gx-lab-sub"><span data-i18n="LabIndex_Subtitle">Create reference sequences and submit them for admin approval.</span></div>
        </div>

        <div class="gx-lab-actions">
            <a class="gx-lab-btn gx-lab-btn--primary" href="/lab/sequences/create"><span data-i18n="LabIndex_CreateBtn">Create sequence</span></a>
        </div>
    </div>

    <div class="gx-lab-card">
        <div class="gx-lab-card__hd">
            <div class="gx-lab-card__title"><span data-i18n="LabIndex_CardTitle">My submissions</span></div>
            <div class="gx-lab-card__meta">@Model.Count <span data-i18n="LabIndex_ItemsSuffix">item(s)</span></div>
        </div>

        @if (Model.Count == 0)
        {
            <div class="gx-lab-empty">
                <div class="gx-lab-empty__title"><span data-i18n="LabIndex_EmptyTitle">No sequences yet</span></div>
                <div class="gx-lab-empty__text"><span data-i18n="LabIndex_EmptyText">Create your first reference sequence and send it for approval.</span></div>
                <a class="gx-lab-btn gx-lab-btn--primary" href="/lab/sequences/create"><span data-i18n="LabIndex_CreateBtn">Create sequence</span></a>
            </div>
        }
        else
        {
            <div class="gx-lab-tablewrap">
                <table class="gx-lab-table">
                    <thead>
                        <tr>
                            <th><span data-i18n="LabIndex_Th_Species">Species</span></th>
                            <th><span data-i18n="LabIndex_Th_Name">Name</span></th>
                            <th class="gx-lab-col--num"><span data-i18n="LabIndex_Th_Length">Length</span></th>
                            <th><span data-i18n="LabIndex_Th_Status">Status</span></th>
                            <th class="gx-lab-col--num"><span data-i18n="LabIndex_Th_Created">Created</span></th>
                            <th class="gx-lab-col--num"><span data-i18n="LabIndex_Th_Updated">Updated</span></th>
                            <th class="gx-lab-col--actions"><span data-i18n="LabIndex_Th_Actions">Actions</span></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model)
                        {
                            var status = s.IsApproved ? "Approved" : (s.IsRejected ? "Rejected" : "Pending");
                            var statusKey = s.IsApproved ? "Lab_Status_Approved" : (s.IsRejected ? "Lab_Status_Rejected" : "Lab_Status_Pending");
                            var statusCls = s.IsApproved ? "gx-lab-pill--ok" : (s.IsRejected ? "gx-lab-pill--bad" : "gx-lab-pill--mid");
                            <tr>
                                <td class="gx-lab-td-strong">@s.Species</td>
                                <td>@s.Name</td>
                                <td class="gx-lab-col--num">@s.Length</td>
                                <td>
                                    <span class="gx-lab-pill @statusCls" data-i18n="@statusKey">@status</span>
                                    @if (s.IsRejected && !string.IsNullOrWhiteSpace(s.RejectionReason))
                                    {
                                        <div class="gx-lab-note"><span data-i18n="LabIndex_ReasonLabel">Reason:</span> @s.RejectionReason</div>
                                    }
                                </td>
                                <td class="gx-lab-col--num gx-lab-muted">@s.CreatedAt</td>
                                <td class="gx-lab-col--num gx-lab-muted">@(!string.IsNullOrWhiteSpace(s.UpdatedAt) ? s.UpdatedAt : "—")</td>
                                <td class="gx-lab-col--actions">
                                    @if (!s.IsApproved)
                                    {
                                        <a class="gx-lab-link" href="/lab/sequences/edit/@s.Id"><span data-i18n="Common_Edit">Edit</span></a>

                                        <form class="gx-lab-inline" method="post" action="/lab/sequences/delete/@s.Id">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="gx-lab-link gx-lab-link--danger"
                                                    data-i18n-confirm="LabIndex_DeleteConfirm" onclick="return gxConfirm(this, 'Delete this sequence? This cannot be undone.');">
                                                <span data-i18n="Common_Delete">Delete</span>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="gx-lab-muted"><span data-i18n="LabIndex_Locked">Locked</span></span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="~/js/lab-i18n.js" asp-append-version="true"></script>
}
