@model CreateReferenceSequenceViewModel

@{
    ViewData["Title"] = "Create Sequence";
}


<div class="gx-lab-page">
    <div class="gx-lab-head">
        <div>
            <h1 class="gx-lab-title">Create reference sequence</h1>
            <div class="gx-lab-sub">Your submission will be pending until an admin approves it.</div>
        </div>

        <div class="gx-lab-actions">
            <a class="gx-lab-btn" href="/lab/sequences">Back</a>
        </div>
    </div>

    <div class="gx-lab-card">
        <form method="post" action="/lab/sequences/create" class="gx-lab-form">
            @Html.AntiForgeryToken()

            <div class="gx-lab-grid">
                <div class="gx-lab-field">
                    <label class="gx-lab-label" asp-for="Species"></label>
                    <input class="gx-lab-input" asp-for="Species" autocomplete="off" />
                    <span class="gx-lab-val" asp-validation-for="Species"></span>
                </div>

                <div class="gx-lab-field">
                    <label class="gx-lab-label" asp-for="Name"></label>
                    <input class="gx-lab-input" asp-for="Name" autocomplete="off" />
                    <span class="gx-lab-val" asp-validation-for="Name"></span>
                </div>
            </div>

            <div class="gx-lab-field">
                <label class="gx-lab-label" asp-for="Sequence"></label>
                <textarea class="gx-lab-textarea" asp-for="Sequence" rows="8" spellcheck="false"></textarea>
                <div class="gx-lab-hint">Allowed: A, C, G, T (whitespace ignored by your controller/service normalization).</div>
                <span class="gx-lab-val" asp-validation-for="Sequence"></span>
            </div>

            <div class="gx-lab-footer">
                <button type="submit" class="gx-lab-btn gx-lab-btn--primary">Submit</button>
                <a class="gx-lab-btn" href="/lab/sequences">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}