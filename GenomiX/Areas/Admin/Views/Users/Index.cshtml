@model List<AdminUserListItemViewModel>

@{
    ViewData["Title"] = "Users";
}

<section class="admin-page">
    <header class="admin-head">
        <div>
            <h1 class="admin-title">Users</h1>
            <p class="admin-subtitle">Overview of accounts and roles.</p>
        </div>

        <div class="admin-actions">
            <a class="admin-btn admin-btn--ghost" href="/admin/users/requests">Role requests</a>
        </div>
    </header>

    <div class="admin-card">
        <div class="admin-table-wrap">
            @if (Model.Count == 0)
            {
                <table>
                    <tbody>
                        <tr>
                            <td colspan="6" class="admin-empty">No users found.</td>
                        </tr>
                    </tbody>
                </table>
            }
            else
            {
                <table class="admin-table is-wide admin-table--grid">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Email</th>
                            <th>Roles</th>
                            <th class="admin-col-num">DNAs</th>
                            <th class="admin-col-num">Sims</th>
                            <th class="admin-col-actions">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model)
                        {
                            <tr>
                                <td>
                                    <div class="admin-user">
                                        <div class="admin-user__name">@u.UserName</div>
                                        <div class="admin-user__id">ID: @u.UserId</div>
                                    </div>
                                </td>
                                <td class="admin-muted">@u.Email</td>
                                <td>
                                    <div class="admin-chips">
                                        @foreach (var r in u.Roles)
                                        {
                                            <span class="admin-chip">@r</span>
                                        }
                                    </div>
                                </td>
                                <td class="admin-col-num">@u.DnaModels</td>
                                <td class="admin-col-num">@u.Simulations</td>
                                <td class="admin-col-actions">
                                    <a class="admin-link" href="/admin/users/@u.UserId">Details</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</section>