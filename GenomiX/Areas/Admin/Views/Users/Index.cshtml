@model List<AdminUserListItemViewModel>

@{
    ViewData["Title"] = "Users";
}

<section class="admin-page">
    <header class="admin-head">
        <div>
            <h1 class="admin-title"><span data-i18n="UsersIndex_Title">Users</span></h1>
            <p class="admin-subtitle"><span data-i18n="UsersIndex_Subtitle">Overview of accounts and roles.</span></p>
        </div>

        <div class="admin-actions">
            <a class="admin-btn admin-btn--ghost" href="/admin/users/requests"><span data-i18n="UsersIndex_Btn_RoleRequests">Role requests</span></a>
        </div>
    </header>

    <div class="admin-card">
        <div class="admin-table-wrap">
            @if (Model.Count == 0)
            {
                <table>
                    <tbody>
                        <tr>
                            <td colspan="6" class="admin-empty"><span data-i18n="UsersIndex_Empty">No users found.</span></td>
                        </tr>
                    </tbody>
                </table>
            }
            else
            {
                <table class="admin-table is-wide admin-table--grid">
                    <thead>
                        <tr>
                            <th><span data-i18n="UsersIndex_Th_User">User</span></th>
                            <th><span data-i18n="UsersIndex_Th_Email">Email</span></th>
                            <th><span data-i18n="UsersIndex_Th_Roles">Roles</span></th>
                            <th class="admin-col-num"><span data-i18n="UsersIndex_Th_DNAs">DNAs</span></th>
                            <th class="admin-col-num"><span data-i18n="UsersIndex_Th_Sims">Sims</span></th>
                            <th class="admin-col-actions"><span data-i18n="UsersIndex_Th_Actions">Actions</span></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model)
                        {
                            <tr>
                                <td>
                                    <div class="admin-user">
                                        <div class="admin-user__name">@u.UserName</div>
                                        <div class="admin-user__id"><span data-i18n="Common_IdLabel">ID:</span> @u.UserId</div>
                                    </div>
                                </td>
                                <td class="admin-muted">@u.Email</td>
                                <td>
                                    <div class="admin-chips">
                                        @foreach (var r in u.Roles)
                                        {
                                            <span class="admin-chip">@r</span>
                                        }
                                    </div>
                                </td>
                                <td class="admin-col-num">@u.DnaModels</td>
                                <td class="admin-col-num">@u.Simulations</td>
                                <td class="admin-col-actions">
                                    <a class="admin-link" href="/admin/users/@u.UserId"><span data-i18n="Common_Details">Details</span></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/js/users-i18n.js" asp-append-version="true"></script>
}
