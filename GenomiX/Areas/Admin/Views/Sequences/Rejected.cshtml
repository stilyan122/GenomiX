@model IReadOnlyList<AdminReferenceSequenceListItemViewModel>

@{
    ViewData["Title"] = "Rejected Sequences";
}

<div class="gx-admin-page">
    <div class="gx-admin-head">
        <div>
            <h1 class="gx-admin-title"><span data-i18n="AdminRejected_Title">Rejected</span></h1>
            <div class="gx-admin-sub"><span data-i18n="AdminRejected_Subtitle">Rejected submissions remain editable by the scientist.</span></div>
        </div>

        <div class="gx-admin-tabs">
            <a class="gx-admin-tab" href="/admin/sequences"><span data-i18n="AdminTabs_Pending">Pending</span></a>
            <a class="gx-admin-tab" href="/admin/sequences/approved"><span data-i18n="AdminTabs_Approved">Approved</span></a>
            <a class="gx-admin-tab is-active" href="/admin/sequences/rejected"><span data-i18n="AdminTabs_Rejected">Rejected</span></a>
        </div>
    </div>

    <div class="gx-admin-card">
        @if (Model.Count == 0)
        {
            <div class="gx-admin-empty">
                <div class="gx-admin-empty__title"><span data-i18n="AdminRejected_EmptyTitle">No rejected items</span></div>
                <div class="gx-admin-empty__text">Rejected sequences will show here.</div>
            </div>
        }
        else
        {
            <div class="gx-admin-tablewrap">
                <table class="gx-admin-table">
                    <thead>
                        <tr>
                            <th><span data-i18n="Admin_Th_Species">Species</span></th>
                            <th><span data-i18n="Admin_Th_Name">Name</span></th>
                            <th class="gx-admin-col--num"><span data-i18n="Admin_Th_Length">Length</span></th>
                            <th class="gx-admin-col--num"><span data-i18n="Admin_Th_CreatedOn">Created On</span></th>
                            <th class="gx-admin-col--num"><span data-i18n="Admin_Th_CreatedBy">Created By</span></th>
                            <th class="gx-admin-col--actions"><span data-i18n="Admin_Th_Details">Details</span></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model)
                        {
                            <tr>
                                <td class="gx-admin-td-strong">@s.Species</td>
                                <td>@s.Name</td>
                                <td class="gx-admin-col--num">@s.Length</td>
                                <td class="gx-admin-col--num gx-admin-muted">@s.CreatedAt</td>
                                <td class="gx-admin-col--num gx-admin-muted">@s.CreatedBy</td>
                                <td class="gx-admin-col--actions">
                                    <a class="gx-admin-link" href="/admin/sequences/review/@s.Id"><span data-i18n="Common_Open">Open</span></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="~/js/admin-i18n.js" asp-append-version="true"></script>
}
